#!/usr/bin/env bash
# Run by the meeting monitor's trap on EXIT / INT / TERM.
# Cleans up everything that identified this session as "alive":
#   1. /tmp/meeting-<name>.monitor_pid  — liveness signal file
#   2. ~/.agent-meeting/directory.json  — entry for <name>
#
# After cleanup, the session name disappears from `room list` entirely
# (unless it has messages in DB, in which case it shows as `historical`).
# No more `empty` zombie state from sessions that exited normally.
#
# Usage: session-cleanup <name>
set -e

NAME="${1:-}"
[ -z "$NAME" ] && exit 0

PID_FILE="/tmp/meeting-${NAME}.monitor_pid"
DIR="$HOME/.agent-meeting/directory.json"
TMP="/tmp/dir.cleanup.$$.tmp"

rm -f "$PID_FILE"

if [ -f "$DIR" ]; then
  # Atomic delete via jq + mv. Skip if jq missing or directory unparseable
  # — leftover entry is harmless and will show as `empty` until next manual cleanup.
  if jq --arg n "$NAME" 'del(.[$n])' "$DIR" > "$TMP" 2>/dev/null; then
    mv "$TMP" "$DIR"
  else
    rm -f "$TMP"
  fi
fi
