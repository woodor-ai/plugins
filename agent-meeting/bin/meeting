#!/usr/bin/env python3
"""
meeting-meeting CLI backed by SQLite.

Replaces the file-per-room storage (canonical/*.md) that suffered from:
  - Edit/Write race conditions (no atomic locking)
  - Lost-update on concurrent peer writes
  - 150-line manual archive discipline that nobody followed
  - Turn-flag parsing via grep
  - Monitor mtime false positives (prefix matching bug)

SQLite gives us atomic transactions, version-based optimistic concurrency,
unlimited history with O(log N) reads, and clean query semantics.

Database: ~/.claude/meeting/db/rooms.db (WAL mode for concurrent readers).

Usage:
  meeting init                                          # ensure db + schema
  meeting send <self> <peer> <body> [--kind=X] [--ask=Y]
  meeting read <self> <peer> [--limit=30] [--since=ID]
  meeting show <self> <peer> [--limit=30]               # human-readable markdown render
  meeting turn <self> <peer>                            # whose turn is it
  meeting ring <self> --since <ID>                      # monitor query: new msgs in rooms where turn=self
  meeting list                                          # all rooms
  meeting register <name> --cwd <cwd>                   # register session in central sessions table
  meeting unregister <name>                             # remove session from central sessions table

All write operations are wrapped in BEGIN IMMEDIATE transactions, so two
sessions writing the same room simultaneously serialize cleanly.
"""

import argparse
import http.client as _http_client
import json
import os
import secrets
import socket
import sqlite3
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.parse
import urllib.request

# Data root is agent-neutral so the same plugin works under Claude Code, Codex,
# or any other host. Override with MEETING_HOME env var when testing.
MEETING_HOME = os.environ.get("MEETING_HOME") or os.path.expanduser("~/.agent-meeting")
DB_PATH = os.path.join(MEETING_HOME, "db", "rooms.db")

_TELEMETRY_URL = "https://www.woodor.ai/_functions/t"
_CONFIG_PATH = os.path.join(MEETING_HOME, "config.json")

if sys.platform == "darwin":
    _OS_LABEL = "mac"
elif sys.platform.startswith("win"):
    _OS_LABEL = "win"
else:
    _OS_LABEL = "linux"


def beacon(event: str):
    """Fire-and-forget telemetry. Skipped when MEETING_NO_TELEMETRY is set or
    config.json has telemetry=false (absent/null counts as enabled)."""
    if os.environ.get("MEETING_NO_TELEMETRY"):
        return

    def _send():
        try:
            cfg = {}
            try:
                with open(_CONFIG_PATH) as _f:
                    cfg = json.load(_f)
            except Exception:
                pass
            if cfg.get("telemetry") is False:
                return
            machine_id = cfg.get("machine_id", "unknown")
            version = cfg.get("plugin_version", "unknown")
            params = urllib.parse.urlencode({
                "e": event,
                "id": machine_id,
                "v": version,
                "os": _OS_LABEL,
            })
            url = f"{_TELEMETRY_URL}?{params}"
            urllib.request.urlopen(url, timeout=2)
        except Exception:
            pass

    t = threading.Thread(target=_send, daemon=True)
    t.start()

# Discovery cache: avoid 1-2s mDNS browse on every CLI call (monitor polls ring/3s).
HOST_CACHE = os.path.join(tempfile.gettempdir(), "meeting-host.cache")
HOST_CACHE_TTL = 60  # seconds
MDNS_BROWSE_TIMEOUT = 1.5  # seconds
SERVICE_TYPE = "_agent-meeting._tcp.local."

# A session is considered online if last_seen is within this many seconds.
# monitor polls /ring every 3s, so 4 missed heartbeats = 12s.
ONLINE_THRESHOLD = 12

_NO_CONTROL_MSG = (
    "未发现中央节点 (agent-meeting-control)。"
    "请先用 /meeting daemon 把本机设为中央节点，或确认目标 control 在线且同网段。"
)


# ---------- LAN discovery (mDNS + HTTP client) ----------

def discover_controls() -> list[dict]:
    """Enumerate ALL _agent-meeting._tcp instances on the LAN.

    Returns a list of dicts: {url, host, ip, port, version}.
    host/version are taken from mDNS TXT properties — no extra HTTP call.
    Empty list when zeroconf is unavailable or nothing found.
    """
    if os.environ.get("MEETING_HOST"):
        url = os.environ["MEETING_HOST"].rstrip("/")
        # Parse host/ip/port from the override URL for a consistent return shape.
        parsed = urllib.parse.urlparse(url)
        ip = parsed.hostname or ""
        port = parsed.port or 8765
        return [{"url": url, "host": ip, "ip": ip, "port": port, "version": ""}]

    try:
        from zeroconf import IPVersion, ServiceBrowser, ServiceListener, Zeroconf
    except ImportError:
        return []

    found: list[dict] = []

    class _L(ServiceListener):
        def add_service(self, zc, type_, name):
            info = zc.get_service_info(type_, name, timeout=int(MDNS_BROWSE_TIMEOUT * 1000))
            if info and info.addresses:
                ip = socket.inet_ntoa(info.addresses[0])
                port = info.port
                url = f"http://{ip}:{port}"
                props = info.properties or {}
                host = (props.get(b"host") or b"").decode("utf-8", errors="replace")
                version = (props.get(b"version") or b"").decode("utf-8", errors="replace")
                found.append({"url": url, "host": host, "ip": ip, "port": port, "version": version})

        def update_service(self, *a): pass
        def remove_service(self, *a): pass

    for _attempt in range(3):
        try:
            zc = Zeroconf(ip_version=IPVersion.V4Only)
            ServiceBrowser(zc, SERVICE_TYPE, _L())
            time.sleep(MDNS_BROWSE_TIMEOUT)
            zc.close()
        except Exception:
            return found
        if found:
            break

    return found


def discover_host() -> str | None:
    """Find a remote daemon to talk to. Returns base URL or None.

    Resolution order:
      1. MEETING_HOST env var (e.g. http://10.0.0.114:8765) — manual override.
      2. /tmp/meeting-host.cache — recently discovered URL, valid for HOST_CACHE_TTL.
      3. mDNS browse via discover_controls() (1.5s).
      4. None → no control found; caller must error out.
    """
    if os.environ.get("MEETING_HOST"):
        return os.environ["MEETING_HOST"].rstrip("/")

    if os.path.exists(HOST_CACHE):
        try:
            with open(HOST_CACHE) as f:
                cache = json.load(f)
            if cache.get("expires", 0) > time.time() and cache.get("url"):
                return cache["url"]
        except Exception:
            pass

    controls = discover_controls()
    if not controls:
        return None

    # Prefer the cached "last used" URL if it's still in the discovered set;
    # otherwise fall back to the first discovered control.
    url = controls[0]["url"]
    try:
        with open(HOST_CACHE, "w") as f:
            json.dump({"url": url, "expires": time.time() + HOST_CACHE_TTL}, f)
    except Exception:
        pass
    return url


def _invalidate_host_cache():
    try:
        os.remove(HOST_CACHE)
    except Exception:
        pass


def _resolve_host(explicit: str | None = None) -> str:
    """Return the control URL to use for this command, or raise SystemExit.

    If explicit is given (from --host flag), use it directly.
    Otherwise call discover_host(). Raises SystemExit with a clear Chinese
    error message when no control is found.
    """
    if explicit:
        return explicit.rstrip("/")
    url = discover_host()
    if url:
        return url
    raise SystemExit(_NO_CONTROL_MSG)


def _get_auth_token() -> str | None:
    """Return the auth token to send with requests.

    Priority: MEETING_TOKEN env var > config.json auth_token.
    Returns None when neither is set (open-mode daemon).
    """
    env_tok = os.environ.get("MEETING_TOKEN")
    if env_tok:
        return env_tok
    try:
        with open(_CONFIG_PATH) as _f:
            return json.load(_f).get("auth_token") or None
    except Exception:
        return None


def _http_once(method: str, host_url: str, path: str,
               params: dict | None, body: dict | None):
    """Single HTTP attempt. Returns parsed JSON or raw text. Raises on non-2xx."""
    url = host_url + path
    if params:
        url += "?" + urllib.parse.urlencode(params)
    headers = {}
    token = _get_auth_token()
    if token:
        headers["Authorization"] = f"Bearer {token}"
    data = None
    if body is not None:
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json; charset=utf-8"
    req = urllib.request.Request(url, method=method, data=data, headers=headers)
    with urllib.request.urlopen(req, timeout=10) as resp:
        ct = resp.headers.get("Content-Type", "")
        raw = resp.read()
        if "application/json" in ct:
            return json.loads(raw.decode("utf-8"))
        return raw.decode("utf-8")


def http(method: str, host_url: str, path: str,
         params: dict | None = None, body: dict | None = None):
    """Call the daemon. Returns parsed JSON or raw text. Raises on non-2xx.

    Catches broken-connection errors (RemoteDisconnected, IncompleteRead,
    socket.timeout, ConnectionError) in addition to HTTPError/URLError.
    On a broken-connection error: invalidate host cache, retry once with a
    freshly discovered host. If that also fails, raise SystemExit — there is
    no local-SQLite fallback (a missing control is a hard error, see
    _resolve_host).
    """
    _BROKEN = (
        _http_client.RemoteDisconnected,
        _http_client.IncompleteRead,
        ConnectionError,
        socket.timeout,
        TimeoutError,
    )
    try:
        return _http_once(method, host_url, path, params, body)
    except urllib.error.HTTPError as e:
        err = e.read().decode("utf-8", errors="replace")
        raise SystemExit(f"daemon error: HTTP {e.code}: {err}")
    except urllib.error.URLError as e:
        _invalidate_host_cache()
        raise SystemExit(f"daemon unreachable at {host_url}: {e.reason}")
    except _BROKEN as e:
        # Daemon responded but connection died mid-flight (e.g. FD exhaustion
        # on the server side). Invalidate cache and retry once with a freshly
        # discovered host.
        _invalidate_host_cache()
        new_host = discover_host()
        if new_host is None:
            raise SystemExit(f"daemon connection broken and no daemon found on retry: {e}")
        try:
            return _http_once(method, new_host, path, params, body)
        except Exception as e2:
            raise SystemExit(f"daemon unreachable after retry: {e2}") from e2

SCHEMA = """
PRAGMA journal_mode = WAL;
PRAGMA foreign_keys = ON;

CREATE TABLE IF NOT EXISTS rooms (
  id INTEGER PRIMARY KEY,
  name TEXT UNIQUE NOT NULL,           -- canonical name: sorted([a,b]).join('--')
  participant_a TEXT NOT NULL,         -- lexicographically first
  participant_b TEXT NOT NULL,
  current_turn TEXT NOT NULL,          -- one of participant_a/b
  created_at INTEGER NOT NULL          -- unix seconds
);

CREATE TABLE IF NOT EXISTS messages (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  room_id INTEGER NOT NULL REFERENCES rooms(id),
  sender TEXT NOT NULL,
  kind TEXT NOT NULL,                  -- 开启|回应|总结
  body TEXT NOT NULL,
  ask TEXT,                            -- nullable; the **Ask** line of this msg
  created_at INTEGER NOT NULL          -- unix seconds
);

CREATE INDEX IF NOT EXISTS idx_messages_room_id ON messages(room_id, id);

CREATE TABLE IF NOT EXISTS sessions (
  name TEXT PRIMARY KEY,
  cwd TEXT,
  host TEXT,
  registered_at TEXT,
  last_seen REAL,                       -- epoch seconds (float); heartbeat via /ring
  role TEXT NOT NULL DEFAULT 'worker'
);
"""


# ---------- connection ----------

def connect():
    db = sqlite3.connect(DB_PATH, isolation_level=None, timeout=30)
    db.row_factory = sqlite3.Row
    db.executescript("PRAGMA journal_mode = WAL; PRAGMA foreign_keys = ON;")
    return db


def init_db():
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    db = connect()
    db.executescript(SCHEMA)
    try:
        db.execute("ALTER TABLE sessions ADD COLUMN role TEXT NOT NULL DEFAULT 'worker'")
    except sqlite3.OperationalError:
        pass
    try:
        db.execute("ALTER TABLE sessions ADD COLUMN os TEXT")
    except sqlite3.OperationalError:
        pass
    db.close()


# ---------- helpers ----------

def canonical_room_name(a: str, b: str) -> tuple[str, str, str]:
    """Sort two participants lexicographically. Returns (name, a, b)."""
    sa, sb = sorted([a, b])
    return f"{sa}--{sb}", sa, sb


def ensure_room(db, self_name: str, peer: str) -> sqlite3.Row:
    """Get or create the room for self <-> peer."""
    name, a, b = canonical_room_name(self_name, peer)
    row = db.execute("SELECT * FROM rooms WHERE name=?", (name,)).fetchone()
    if row is None:
        # First message into this room; creator becomes the initial turn-holder via send().
        db.execute(
            "INSERT INTO rooms (name, participant_a, participant_b, current_turn, created_at) "
            "VALUES (?, ?, ?, ?, ?)",
            (name, a, b, self_name, int(time.time())),
        )
        row = db.execute("SELECT * FROM rooms WHERE name=?", (name,)).fetchone()
    return row


# ---------- commands ----------

def cmd_init(args):
    init_db()
    print(f"db ready: {DB_PATH}")


def cmd_send(args):
    """Insert a message; flip turn to peer atomically.

    Body can be passed:
      - inline: room send self peer "hello"
      - from stdin: echo "hello" | room send self peer -
      - from file: room send self peer --body-file=/tmp/reply.md
    Stdin/file is the safe way when body contains backticks, $(...), or other
    shell-special chars that would otherwise get interpreted before argv reaches us.
    """
    if args.body_file:
        with open(args.body_file) as f:
            body = f.read().rstrip("\n")
    elif args.body == "-":
        body = sys.stdin.read().rstrip("\n")
    else:
        body = args.body
    if not body:
        raise SystemExit("error: body is empty")

    host = _resolve_host(getattr(args, "host", None))
    payload = {"self": args.self, "peer": args.peer, "body": body, "kind": args.kind}
    if args.ask:
        payload["ask"] = args.ask
    r = http("POST", host, "/send", body=payload)
    print(f"sent: room={r['room']} msg_id={r['msg_id']} turn→{r['turn']}")
    beacon("send")


def cmd_read(args):
    """Print messages as raw rows: id|created_at|sender|kind|ask|body."""
    host = _resolve_host(getattr(args, "host", None))
    rows = http("GET", host, "/read",
                params={"self": args.self, "peer": args.peer, "limit": args.limit, "since": args.since})
    for r in rows:
        ask = (r.get("ask") or "").replace("\n", " ")
        body = r["body"].replace("\n", "\\n")
        print(f"{r['id']}\t{r['created_at']}\t{r['sender']}\t{r['kind']}\t{ask}\t{body}")


def cmd_show(args):
    """Pretty markdown render of recent messages (for human viewing)."""
    host = _resolve_host(getattr(args, "host", None))
    text = http("GET", host, "/show",
                params={"self": args.self, "peer": args.peer, "limit": args.limit})
    sys.stdout.write(text)


def cmd_turn(args):
    host = _resolve_host(getattr(args, "host", None))
    r = http("GET", host, "/turn", params={"self": args.self, "peer": args.peer})
    print(r["turn"])


def cmd_delete(args):
    """Delete a room (and all its messages) atomically.

    Hard delete — no soft-delete / archive. The caller (SKILL.md) is responsible
    for confirming with the user before invoking this.
    """
    host = _resolve_host(getattr(args, "host", None))
    r = http("DELETE", host, "/room", params={"self": args.self, "peer": args.peer})
    print(f"deleted: room={r['room']} ({r['msg_count']} msgs purged)")


def cmd_ring(args):
    """Monitor query: for self, list new messages in rooms where turn=self.

    Output: one line per message: <msg_id>\t<peer>\t<ask_or_empty>
    Monitor uses this to track the cursor and emit notifications.
    """
    host = _resolve_host(getattr(args, "host", None))
    rows = http("GET", host, "/ring", params={"self": args.self, "since": args.since})
    for r in rows:
        ask = (r.get("ask") or "").replace("\n", " ").replace("\t", " ")
        print(f"{r['id']}\t{r['peer']}\t{ask}")


def cmd_register(args):
    """Register this session in the central sessions table via daemon HTTP POST /register.

    Conflict: if name already exists and last_seen is within ONLINE_THRESHOLD
    seconds, refuse unless --force.
    """
    name = args.name
    cwd = args.cwd
    host_name = socket.gethostname()

    explicit_host = getattr(args, "host", None)
    host = _resolve_host(explicit_host)

    # When --host is given explicitly, persist it as the preferred control.
    if explicit_host:
        try:
            with open(HOST_CACHE, "w") as f:
                json.dump({"url": explicit_host.rstrip("/"), "expires": time.time() + HOST_CACHE_TTL}, f)
        except Exception:
            pass

    payload = {"name": name, "cwd": cwd, "force": args.force, "role": "director" if args.director else None,
               "host": host_name, "os": _OS_LABEL}
    r = http("POST", host, "/register", body=payload)
    if r.get("error"):
        print(r["error"], file=sys.stderr)
        sys.exit(1)
    print(f"registered: {name} (cwd={cwd}, host={host_name})")
    beacon("register")


def cmd_unregister(args):
    """Remove a session from the central sessions table. Silent if not present."""
    name = args.name

    host = _resolve_host(getattr(args, "host", None))
    r = http("POST", host, "/unregister", body={"name": name})
    if r.get("error"):
        print(r["error"], file=sys.stderr)
        sys.exit(1)
    print(f"unregistered: {name}")


LAUNCHD_LABEL = "com.tommy.agent-meeting"
SCHTASKS_TN = "agent-meeting-daemon"
DAEMON_PORT = int(os.environ.get("MEETING_PORT", "8765"))
STOP_SENTINEL = os.path.join(MEETING_HOME, "daemon.stopped")
_DAEMON_PID_FILE = os.path.join(tempfile.gettempdir(), "meeting-daemon.pid")
_SUPERVISOR_PID_FILE = os.path.join(tempfile.gettempdir(), "meeting-supervisor.pid")


def _win_pid_alive(pid: int) -> bool:
    if pid <= 0:
        return False
    import ctypes
    PROCESS_QUERY_LIMITED_INFORMATION = 0x1000
    handle = ctypes.windll.kernel32.OpenProcess(PROCESS_QUERY_LIMITED_INFORMATION, False, pid)
    if not handle:
        return False
    code = ctypes.c_ulong(0)
    ctypes.windll.kernel32.GetExitCodeProcess(handle, ctypes.byref(code))
    ctypes.windll.kernel32.CloseHandle(handle)
    return code.value == 259  # STILL_ACTIVE


def _read_pid(path: str) -> int:
    try:
        with open(path) as f:
            return int(f.read().strip())
    except Exception:
        return 0


def _probe_health() -> dict | None:
    """GET /health from the local daemon. Returns parsed JSON or None."""
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{DAEMON_PORT}/health", timeout=5) as r:
            return json.loads(r.read().decode("utf-8"))
    except Exception:
        return None


def _cmd_daemon_windows(args):
    """Windows daemon management. The daemon is kept alive by supervisor.py
    (launched via a user-level logon scheduled task — see session-bootstrap
    ensure_schtasks). Stop/restart are mediated by the stop sentinel
    (~/.agent-meeting/daemon.stopped): the supervisor relaunches the daemon on
    any exit UNLESS the sentinel is present.
    """
    import subprocess as sp

    if args.action == "status":
        q = sp.run(["schtasks", "/Query", "/TN", SCHTASKS_TN, "/FO", "LIST"],
                   capture_output=True, text=True)
        if q.returncode != 0:
            print(f"logon task: not registered ({SCHTASKS_TN})")
        else:
            for line in q.stdout.splitlines():
                line = line.strip()
                if line.startswith(("TaskName:", "Status:", "Next Run Time:")):
                    print(line)
        sup = _read_pid(_SUPERVISOR_PID_FILE)
        print(f"supervisor: {'running pid='+str(sup) if _win_pid_alive(sup) else 'not running'}")
        dpid = _read_pid(_DAEMON_PID_FILE)
        print(f"daemon proc: {'running pid='+str(dpid) if _win_pid_alive(dpid) else 'not running'}")
        h = _probe_health()
        print(f"daemon /health: {'ok, version '+h.get('version','?') if h else 'unreachable'}")
        if os.path.exists(STOP_SENTINEL):
            print("stop sentinel: PRESENT (supervisor will not relaunch)")
        return

    if args.action == "stop":
        # Authoritative "stay down" signal — write BEFORE killing so the
        # supervisor sees it and exits instead of relaunching.
        try:
            with open(STOP_SENTINEL, "w") as f:
                f.write(str(int(time.time())))
        except Exception as e:
            print(f"could not write stop sentinel: {e}", file=sys.stderr)
        sp.run(["schtasks", "/End", "/TN", SCHTASKS_TN], capture_output=True)
        for pid in (_read_pid(_DAEMON_PID_FILE), _read_pid(_SUPERVISOR_PID_FILE)):
            if pid > 0:
                sp.run(["taskkill", "/F", "/PID", str(pid)], capture_output=True)
        print(f"daemon stopped: {SCHTASKS_TN} (stop sentinel set)")
        print("(note: next Claude SessionStart with is_host=true clears the sentinel "
              "and reinstalls + restarts it)")
        return

    if args.action == "restart":
        # Clear the sentinel first so the supervisor is allowed to relaunch.
        try:
            os.remove(STOP_SENTINEL)
        except FileNotFoundError:
            pass
        # Make sure a supervisor is alive (it owns relaunch); kick the task if not.
        if not _win_pid_alive(_read_pid(_SUPERVISOR_PID_FILE)):
            sp.run(["schtasks", "/Run", "/TN", SCHTASKS_TN], capture_output=True)
        # Kill the current daemon; the supervisor revives a fresh one within a tick.
        dpid = _read_pid(_DAEMON_PID_FILE)
        if dpid > 0:
            sp.run(["taskkill", "/F", "/PID", str(dpid)], capture_output=True)
        print(f"daemon restarting: {SCHTASKS_TN} (supervisor will relaunch a fresh daemon)")
        return


def _cmd_daemon_start(sp, system: str):
    """Bare `meeting daemon` — promote this machine to control node.

    Writes is_host=true into config.json, then installs+starts the daemon via
    the same path the SessionStart hook uses (launchd on Mac, schtasks+supervisor
    on Windows, direct launch on Linux).  Idempotent.
    """
    try:
        with open(_CONFIG_PATH) as f:
            cfg = json.load(f)
    except FileNotFoundError:
        cfg = {}
    cfg["is_host"] = True
    os.makedirs(os.path.dirname(_CONFIG_PATH), exist_ok=True)
    with open(_CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2)

    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT") or os.environ.get("PLUGIN_ROOT") or ""
    if not plugin_root:
        # Infer from this script's location: plugin/bin/meeting → plugin/
        plugin_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))

    bootstrap = os.path.join(MEETING_HOME, "bin", "session-bootstrap.py")
    if os.path.exists(bootstrap):
        env = os.environ.copy()
        env["CLAUDE_PLUGIN_ROOT"] = plugin_root
        result = sp.run([sys.executable, bootstrap], env=env, capture_output=True, text=True)
        if result.returncode != 0:
            sys.stderr.write(result.stderr)
        print("daemon started: this machine is now the control node (agent-meeting-control)")
    else:
        # Fallback: launch daemon directly
        daemon_script = os.path.join(plugin_root, "bin", "meeting-daemon")
        if not os.path.exists(daemon_script):
            raise SystemExit(f"daemon script not found: {daemon_script}")
        import tempfile as _tempfile
        log_file = os.path.join(_tempfile.gettempdir(), "meeting-daemon.log")
        if system == "Windows":
            flags = 0x00000008 | 0x00000200
            sp.Popen([sys.executable, daemon_script, "--port", "8765"],
                     stdout=open(log_file, "a"), stderr=sp.STDOUT,
                     creationflags=flags, close_fds=True)
        else:
            sp.Popen([sys.executable, daemon_script, "--port", "8765"],
                     stdout=open(log_file, "a"), stderr=sp.STDOUT,
                     start_new_session=True, close_fds=True)
        print("daemon started: this machine is now the control node (agent-meeting-control)")


def cmd_daemon(args):
    """Manage the local meeting-daemon.

    Bare `meeting daemon` (no action) → promote this machine to control node.

    Mac: drives the launchd LaunchAgent (com.tommy.agent-meeting). All ops are
    idempotent. SessionStart hook will reinstall/restart the daemon on next
    Claude session if is_host=true, so `stop` is effectively "pause until next
    Claude restart" unless you also set is_host=false in config.json.

    Windows: drives the user-level logon scheduled task (agent-meeting-daemon)
    + supervisor.py via a stop sentinel. See _cmd_daemon_windows.

    Linux: not implemented — the daemon there is session-bound and dies with the
    SessionStart hook's parent shell. We print an error instead of pretending to
    manage it.
    """
    import platform
    import subprocess as sp
    system = platform.system()

    if not args.action:
        return _cmd_daemon_start(sp, system)

    if system == "Windows":
        return _cmd_daemon_windows(args)
    if system != "Darwin":
        print("daemon mgmt not supported on this platform (Linux daemon is session-bound)", file=sys.stderr)
        sys.exit(1)

    uid = os.getuid()
    domain = f"gui/{uid}"
    target = f"{domain}/{LAUNCHD_LABEL}"
    plist = os.path.expanduser(f"~/Library/LaunchAgents/{LAUNCHD_LABEL}.plist")

    if args.action == "status":
        r = sp.run(["launchctl", "print", target], capture_output=True, text=True)
        if r.returncode != 0:
            print(f"daemon: not registered with launchd ({LAUNCHD_LABEL})")
            print(f"plist on disk: {'yes' if os.path.exists(plist) else 'no'}")
            return
        # Pull a few interesting fields out of the print output
        keys = ("state =", "pid =", "program =", "path =")
        for line in r.stdout.splitlines():
            line = line.strip()
            if any(k in line for k in keys):
                print(line)
        # 额外检查：本机应为 control，但 daemon 是否真在监听 :8765
        try:
            cfg = json.load(open(_CONFIG_PATH))
        except Exception:
            cfg = {}
        if cfg.get("is_host"):
            healthy = _probe_health() is not None
            if not healthy:
                print(
                    f"\n⚠ 本机应为 control，但 daemon 未在监听 :{DAEMON_PORT}。"
                    " 修复：launchctl 自愈未生效时跑 'meeting daemon restart'，"
                    " 或重开 Claude 会话触发自动拉起。"
                    " 详见 ~/.agent-meeting/logs/bootstrap.log"
                )

    elif args.action == "stop":
        r = sp.run(["launchctl", "bootout", target], capture_output=True, text=True)
        if r.returncode == 0 or "Could not find" in (r.stderr or "") or "No such process" in (r.stderr or ""):
            # Poll until the service is really gone (daemon's SIGTERM handler unpublishes mDNS first).
            for _ in range(20):  # max ~4s
                time.sleep(0.2)
                p = sp.run(["launchctl", "print", target], capture_output=True)
                if p.returncode != 0:
                    break
            print(f"daemon stopped: {LAUNCHD_LABEL}")
            print("(note: next Claude SessionStart with is_host=true will reinstall + restart it)")
        else:
            print(f"stop failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)

    elif args.action == "restart":
        # `kickstart -k` is launchd's atomic kill+respawn for an already-loaded service.
        # If the service isn't loaded yet, fall back to bootstrap.
        loaded = sp.run(["launchctl", "print", target], capture_output=True).returncode == 0
        if loaded:
            r = sp.run(["launchctl", "kickstart", "-k", target], capture_output=True, text=True)
            if r.returncode == 0:
                print(f"daemon restarted: {LAUNCHD_LABEL}")
                return
            print(f"kickstart failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)
        # Not loaded — bootstrap fresh
        if not os.path.exists(plist):
            print(f"plist missing: {plist}", file=sys.stderr)
            print("Run a Claude SessionStart with is_host=true to install it first.", file=sys.stderr)
            sys.exit(1)
        r = sp.run(["launchctl", "bootstrap", domain, plist], capture_output=True, text=True)
        if r.returncode == 0:
            print(f"daemon started: {LAUNCHD_LABEL}")
        else:
            print(f"bootstrap failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)


def cmd_telemetry(args):
    """Read/write the telemetry flag in config.json."""
    try:
        with open(_CONFIG_PATH) as f:
            cfg = json.load(f)
    except FileNotFoundError:
        cfg = {}

    if args.action == "status":
        flag = cfg.get("telemetry")
        if flag is False:
            config_state = "disabled"
        else:
            config_state = "enabled"
        env_override = bool(os.environ.get("MEETING_NO_TELEMETRY"))
        print(f"telemetry: {config_state} (config.json)")
        if env_override:
            print("MEETING_NO_TELEMETRY is set — environment variable overrides config and forces telemetry off")
    elif args.action == "off":
        cfg["telemetry"] = False
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print("telemetry disabled (config.json)")
    elif args.action == "on":
        cfg["telemetry"] = True
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print("telemetry enabled (config.json)")


def cmd_token(args):
    """Generate, set, or clear the shared auth token in config.json."""
    try:
        with open(_CONFIG_PATH) as f:
            cfg = json.load(f)
    except FileNotFoundError:
        cfg = {}

    value = getattr(args, "value", None)

    if value == "clear":
        cfg.pop("auth_token", None)
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print("auth_token cleared — daemon is now open (no auth required)")
        return

    if value:
        cfg["auth_token"] = value
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print(f"auth_token set: {value}")
        return

    # No value: show existing or generate a new one.
    existing = cfg.get("auth_token")
    if existing:
        print(existing)
        print("(existing token — distribute this to every client machine)")
        return

    new_token = secrets.token_urlsafe(32)
    cfg["auth_token"] = new_token
    with open(_CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2)
    print(new_token)
    print(
        "Token generated and written to config.json. "
        "Run `meeting token <value>` on every client machine to distribute it, "
        "or set the MEETING_TOKEN env var. Keep it secret."
    )


def cmd_controls(args):
    """List all discovered control nodes.

    Default: human-readable text blocks.
    --json: JSON array; each element has host/ip/port/url/version/is_current.
    "未发现 control 节点" (or []) when nothing is found.
    """
    controls = discover_controls()

    # Determine the "current" (last used) URL from the cache.
    current_url = None
    if os.path.exists(HOST_CACHE):
        try:
            with open(HOST_CACHE) as f:
                cache = json.load(f)
            if cache.get("expires", 0) > time.time() and cache.get("url"):
                current_url = cache["url"]
        except Exception:
            pass

    if args.json:
        result = []
        for c in controls:
            result.append({
                "host": c.get("host") or "",
                "ip": c.get("ip") or "",
                "port": c.get("port") or 0,
                "url": c.get("url") or "",
                "version": c.get("version") or "",
                "is_current": c["url"] == current_url,
            })
        print(json.dumps(result, ensure_ascii=False))
        return

    if not controls:
        print("未发现 control 节点")
        return

    for i, c in enumerate(controls):
        is_current = c["url"] == current_url
        current_tag = "  ★ 当前" if is_current else ""
        print(f"control {i + 1}{current_tag}")
        print(f"  host:    {c['host'] or '(unknown)'}")
        print(f"  ip:port: {c['ip']}:{c['port']}")
        print(f"  url:     {c['url']}")
        print(f"  version: {c['version'] or '(unknown)'}")

def cmd_list(args):
    """List all session names with liveness status and message count.

    Columns: <status>\t<name>\t<msgs>
      status: online | empty | historical
    """
    host = _resolve_host(getattr(args, "host", None))
    rows = http("GET", host, "/list")
    for r in rows:
        print(f"{r['status']}\t{r['name']}\t{r['msgs']}\t{r.get('role') or 'worker'}\t{r.get('cwd') or ''}\t{r.get('host') or ''}\t{r.get('os') or ''}")


# ---------- main ----------

def main():
    p = argparse.ArgumentParser(prog="meeting")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("init").set_defaults(func=cmd_init)

    s = sub.add_parser("send", help="insert a message and flip turn")
    s.add_argument("self", help="sender name (your registered meeting name)")
    s.add_argument("peer", help="peer name")
    s.add_argument("body", nargs="?", default=None,
                   help="message body inline; or `-` to read stdin; ignored when --body-file given")
    s.add_argument("--body-file", default=None,
                   help="path to a file containing the body — use this for any body with backticks, $(...), or other shell-special chars")
    s.add_argument("--kind", default="回应",
                   help="message kind/header, typically 开启|回应|总结 but any string allowed")
    s.add_argument("--ask", default=None, help="optional one-line ask")
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); applies to this command only, not persisted")
    s.set_defaults(func=cmd_send)

    s = sub.add_parser("read", help="dump messages as TSV rows")
    s.add_argument("self")
    s.add_argument("peer")
    s.add_argument("--limit", type=int, default=30)
    s.add_argument("--since", type=int, default=0, help="only msgs with id > since")
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); applies to this command only, not persisted")
    s.set_defaults(func=cmd_read)

    s = sub.add_parser("show", help="pretty markdown render")
    s.add_argument("self")
    s.add_argument("peer")
    s.add_argument("--limit", type=int, default=30)
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); applies to this command only, not persisted")
    s.set_defaults(func=cmd_show)

    s = sub.add_parser("turn", help="print current turn-holder")
    s.add_argument("self")
    s.add_argument("peer")
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); applies to this command only, not persisted")
    s.set_defaults(func=cmd_turn)

    s = sub.add_parser("ring", help="monitor query: new msgs in rooms where turn=self")
    s.add_argument("self")
    s.add_argument("--since", type=int, default=0, help="only msgs with id > since")
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); applies to this command only, not persisted")
    s.set_defaults(func=cmd_ring)

    s = sub.add_parser("list",
                       help="list all session names with status (online/empty/historical) + msg count")
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); applies to this command only, not persisted")
    s.set_defaults(func=cmd_list)

    s = sub.add_parser("delete", help="delete a room and all its messages (hard delete, atomic)")
    s.add_argument("self")
    s.add_argument("peer")
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); applies to this command only, not persisted")
    s.set_defaults(func=cmd_delete)

    s = sub.add_parser("daemon",
                       help="manage the local meeting daemon; bare `daemon` promotes this machine to control node")
    s.add_argument("action", nargs="?", choices=["status", "stop", "restart"], default=None)
    s.set_defaults(func=cmd_daemon)

    s = sub.add_parser("controls",
                       help="list all discovered control nodes (human-readable, or --json for structured output)")
    s.add_argument("--json", action="store_true", default=False,
                   help="output JSON array instead of human-readable text")
    s.set_defaults(func=cmd_controls)

    s = sub.add_parser("telemetry",
                       help="view or change the telemetry opt-in/out setting in config.json")
    s.add_argument("action", choices=["on", "off", "status"])
    s.set_defaults(func=cmd_telemetry)

    s = sub.add_parser("token",
                       help="manage the shared auth token (host: generate; client: paste host token; clear: disable auth)")
    s.add_argument("value", nargs="?", default=None,
                   help="token value to write, or 'clear' to remove it; omit to show/generate")
    s.set_defaults(func=cmd_token)

    s = sub.add_parser("register",
                       help="register this session in the central sessions table")
    s.add_argument("name", help="session name to register")
    s.add_argument("--cwd", required=True, help="working directory of this session")
    s.add_argument("--force", action="store_true",
                   help="override even if monitor is still running")
    s.add_argument("--director", action="store_true",
                   help="register this session as a director (default: worker)")
    s.add_argument("--host", default=None,
                   help="explicitly specify control URL (e.g. http://10.0.0.5:8765); saved as preferred control")
    s.set_defaults(func=cmd_register)

    s = sub.add_parser("unregister",
                       help="remove this session from the central sessions table (via the control daemon)")
    s.add_argument("name", help="session name to unregister")
    s.set_defaults(func=cmd_unregister)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
