#!/usr/bin/env python3
"""
meeting-meeting CLI backed by SQLite.

Replaces the file-per-room storage (canonical/*.md) that suffered from:
  - Edit/Write race conditions (no atomic locking)
  - Lost-update on concurrent peer writes
  - 150-line manual archive discipline that nobody followed
  - Turn-flag parsing via grep
  - Monitor mtime false positives (prefix matching bug)

SQLite gives us atomic transactions, version-based optimistic concurrency,
unlimited history with O(log N) reads, and clean query semantics.

Database: ~/.claude/meeting/db/rooms.db (WAL mode for concurrent readers).

Usage:
  meeting init                                          # ensure db + schema
  meeting send <self> <peer> <body> [--kind=X] [--ask=Y]
  meeting read <self> <peer> [--limit=30] [--since=ID]
  meeting show <self> <peer> [--limit=30]               # human-readable markdown render
  meeting turn <self> <peer>                            # whose turn is it
  meeting ring <self> --since <ID>                      # monitor query: new msgs in rooms where turn=self
  meeting list                                          # all rooms

All write operations are wrapped in BEGIN IMMEDIATE transactions, so two
sessions writing the same room simultaneously serialize cleanly.
"""

import argparse
import http.client as _http_client
import json
import os
import socket
import sqlite3
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request

# Data root is agent-neutral so the same plugin works under Claude Code, Codex,
# or any other host. Override with MEETING_HOME env var when testing.
MEETING_HOME = os.environ.get("MEETING_HOME") or os.path.expanduser("~/.agent-meeting")
DB_PATH = os.path.join(MEETING_HOME, "db", "rooms.db")
DIRECTORY_PATH = os.path.join(MEETING_HOME, "directory.json")

# Discovery cache: avoid 1-2s mDNS browse on every CLI call (monitor polls ring/3s).
HOST_CACHE = os.path.join(tempfile.gettempdir(), "meeting-host.cache")
HOST_CACHE_TTL = 60  # seconds
MDNS_BROWSE_TIMEOUT = 1.5  # seconds
SERVICE_TYPE = "_agent-meeting._tcp.local."


# ---------- LAN discovery (mDNS + HTTP client) ----------

def discover_host() -> str | None:
    """Find a remote daemon to talk to. Returns base URL or None.

    Resolution order:
      1. MEETING_HOST env var (e.g. http://10.0.0.114:8765) — manual override.
      2. /tmp/meeting-host.cache — recently discovered URL, valid for HOST_CACHE_TTL.
      3. mDNS browse for _agent-meeting._tcp.local. (1.5s).
      4. None → caller falls back to local SQLite (works only on the host machine).
    """
    if os.environ.get("MEETING_HOST"):
        return os.environ["MEETING_HOST"].rstrip("/")

    if os.path.exists(HOST_CACHE):
        try:
            with open(HOST_CACHE) as f:
                cache = json.load(f)
            if cache.get("expires", 0) > time.time() and cache.get("url"):
                return cache["url"]
        except Exception:
            pass

    try:
        from zeroconf import IPVersion, ServiceBrowser, ServiceListener, Zeroconf
    except ImportError:
        return None

    found_url = []

    class _L(ServiceListener):
        def add_service(self, zc, type_, name):
            info = zc.get_service_info(type_, name, timeout=int(MDNS_BROWSE_TIMEOUT * 1000))
            if info and info.addresses:
                ip = socket.inet_ntoa(info.addresses[0])
                found_url.append(f"http://{ip}:{info.port}")

        def update_service(self, *a): pass
        def remove_service(self, *a): pass

    # Retry up to 2 times so cold-start mDNS has up to ~3x 1.5s ≈ 4.5s total.
    for _attempt in range(3):
        try:
            zc = Zeroconf(ip_version=IPVersion.V4Only)
            ServiceBrowser(zc, SERVICE_TYPE, _L())
            time.sleep(MDNS_BROWSE_TIMEOUT)
            zc.close()
        except Exception:
            return None
        if found_url:
            break

    if not found_url:
        return None

    url = found_url[0]
    try:
        with open(HOST_CACHE, "w") as f:
            json.dump({"url": url, "expires": time.time() + HOST_CACHE_TTL}, f)
    except Exception:
        pass
    return url


def _invalidate_host_cache():
    try:
        os.remove(HOST_CACHE)
    except Exception:
        pass


def _http_once(method: str, host_url: str, path: str,
               params: dict | None, body: dict | None):
    """Single HTTP attempt. Returns parsed JSON or raw text. Raises on non-2xx."""
    url = host_url + path
    if params:
        url += "?" + urllib.parse.urlencode(params)
    headers = {}
    data = None
    if body is not None:
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json; charset=utf-8"
    req = urllib.request.Request(url, method=method, data=data, headers=headers)
    with urllib.request.urlopen(req, timeout=10) as resp:
        ct = resp.headers.get("Content-Type", "")
        raw = resp.read()
        if "application/json" in ct:
            return json.loads(raw.decode("utf-8"))
        return raw.decode("utf-8")


def http(method: str, host_url: str, path: str,
         params: dict | None = None, body: dict | None = None):
    """Call the daemon. Returns parsed JSON or raw text. Raises on non-2xx.

    Catches broken-connection errors (RemoteDisconnected, IncompleteRead,
    socket.timeout, ConnectionError) in addition to HTTPError/URLError.
    On a broken-connection error: invalidate host cache, retry once. If the
    retry also fails, fall back to local SQLite (caller detects None return).
    """
    _BROKEN = (
        _http_client.RemoteDisconnected,
        _http_client.IncompleteRead,
        ConnectionError,
        socket.timeout,
        TimeoutError,
    )
    try:
        return _http_once(method, host_url, path, params, body)
    except urllib.error.HTTPError as e:
        err = e.read().decode("utf-8", errors="replace")
        raise SystemExit(f"daemon error: HTTP {e.code}: {err}")
    except urllib.error.URLError as e:
        _invalidate_host_cache()
        raise SystemExit(f"daemon unreachable at {host_url}: {e.reason}")
    except _BROKEN as e:
        # Daemon responded but connection died mid-flight (e.g. FD exhaustion
        # on the server side). Invalidate cache and retry once with a freshly
        # discovered host.
        _invalidate_host_cache()
        new_host = discover_host()
        if new_host is None:
            raise SystemExit(f"daemon connection broken and no daemon found on retry: {e}")
        try:
            return _http_once(method, new_host, path, params, body)
        except Exception as e2:
            raise SystemExit(f"daemon unreachable after retry: {e2}") from e2

SCHEMA = """
PRAGMA journal_mode = WAL;
PRAGMA foreign_keys = ON;

CREATE TABLE IF NOT EXISTS rooms (
  id INTEGER PRIMARY KEY,
  name TEXT UNIQUE NOT NULL,           -- canonical name: sorted([a,b]).join('--')
  participant_a TEXT NOT NULL,         -- lexicographically first
  participant_b TEXT NOT NULL,
  current_turn TEXT NOT NULL,          -- one of participant_a/b
  created_at INTEGER NOT NULL          -- unix seconds
);

CREATE TABLE IF NOT EXISTS messages (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  room_id INTEGER NOT NULL REFERENCES rooms(id),
  sender TEXT NOT NULL,
  kind TEXT NOT NULL,                  -- 开启|回应|总结
  body TEXT NOT NULL,
  ask TEXT,                            -- nullable; the **Ask** line of this msg
  created_at INTEGER NOT NULL          -- unix seconds
);

CREATE INDEX IF NOT EXISTS idx_messages_room_id ON messages(room_id, id);
"""


# ---------- connection ----------

def connect():
    db = sqlite3.connect(DB_PATH, isolation_level=None, timeout=30)
    db.row_factory = sqlite3.Row
    db.executescript("PRAGMA journal_mode = WAL; PRAGMA foreign_keys = ON;")
    return db


def init_db():
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    db = connect()
    db.executescript(SCHEMA)
    db.close()


# ---------- helpers ----------

def canonical_room_name(a: str, b: str) -> tuple[str, str, str]:
    """Sort two participants lexicographically. Returns (name, a, b)."""
    sa, sb = sorted([a, b])
    return f"{sa}--{sb}", sa, sb


def pid_alive(pid: int) -> bool:
    if sys.platform == "win32":
        import ctypes
        PROCESS_QUERY_LIMITED_INFORMATION = 0x1000
        handle = ctypes.windll.kernel32.OpenProcess(PROCESS_QUERY_LIMITED_INFORMATION, False, pid)
        if not handle:
            return False
        exit_code = ctypes.c_ulong(0)
        ctypes.windll.kernel32.GetExitCodeProcess(handle, ctypes.byref(exit_code))
        ctypes.windll.kernel32.CloseHandle(handle)
        return exit_code.value == 259  # STILL_ACTIVE
    else:
        try:
            os.kill(pid, 0)
        except OSError:
            return False
        return True


def monitor_alive(name: str) -> bool:
    pid_path = os.path.join(tempfile.gettempdir(), f"meeting-{name}.monitor_pid")
    if not os.path.exists(pid_path):
        return False
    try:
        with open(pid_path) as f:
            pid = int(f.read().strip())
        return pid_alive(pid)
    except (ValueError, OSError):
        return False


def ensure_room(db, self_name: str, peer: str) -> sqlite3.Row:
    """Get or create the room for self <-> peer."""
    name, a, b = canonical_room_name(self_name, peer)
    row = db.execute("SELECT * FROM rooms WHERE name=?", (name,)).fetchone()
    if row is None:
        # First message into this room; creator becomes the initial turn-holder via send().
        db.execute(
            "INSERT INTO rooms (name, participant_a, participant_b, current_turn, created_at) "
            "VALUES (?, ?, ?, ?, ?)",
            (name, a, b, self_name, int(time.time())),
        )
        row = db.execute("SELECT * FROM rooms WHERE name=?", (name,)).fetchone()
    return row


# ---------- commands ----------

def cmd_init(args):
    init_db()
    print(f"db ready: {DB_PATH}")


def cmd_send(args):
    """Insert a message; flip turn to peer atomically.

    Body can be passed:
      - inline: room send self peer "hello"
      - from stdin: echo "hello" | room send self peer -
      - from file: room send self peer --body-file=/tmp/reply.md
    Stdin/file is the safe way when body contains backticks, $(...), or other
    shell-special chars that would otherwise get interpreted before argv reaches us.
    """
    if args.body_file:
        with open(args.body_file) as f:
            body = f.read().rstrip("\n")
    elif args.body == "-":
        body = sys.stdin.read().rstrip("\n")
    else:
        body = args.body
    if not body:
        raise SystemExit("error: body is empty")

    host = discover_host()
    if host:
        url = host
        payload = {"self": args.self, "peer": args.peer, "body": body, "kind": args.kind}
        if args.ask:
            payload["ask"] = args.ask
        r = http("POST", url, "/send", body=payload)
        print(f"sent: room={r['room']} msg_id={r['msg_id']} turn→{r['turn']}")
        return

    db = connect()
    db.execute("BEGIN IMMEDIATE")
    try:
        room = ensure_room(db, args.self, args.peer)
        # Validate that self is a participant.
        if args.self not in (room["participant_a"], room["participant_b"]):
            raise SystemExit(f"error: {args.self} is not a participant in room {room['name']}")
        db.execute(
            "INSERT INTO messages (room_id, sender, kind, body, ask, created_at) "
            "VALUES (?, ?, ?, ?, ?, ?)",
            (room["id"], args.self, args.kind, body, args.ask, int(time.time())),
        )
        # Flip turn to peer.
        db.execute("UPDATE rooms SET current_turn=? WHERE id=?", (args.peer, room["id"]))
        msg_id = db.execute("SELECT last_insert_rowid()").fetchone()[0]
        db.execute("COMMIT")
        print(f"sent: room={room['name']} msg_id={msg_id} turn→{args.peer}")
    except Exception:
        db.execute("ROLLBACK")
        raise
    finally:
        db.close()


def cmd_read(args):
    """Print messages as raw rows: id|created_at|sender|kind|ask|body."""
    host = discover_host()
    if host:
        url = host
        rows = http("GET", url, "/read",
                    params={"self": args.self, "peer": args.peer, "limit": args.limit, "since": args.since})
        for r in rows:
            ask = (r.get("ask") or "").replace("\n", " ")
            body = r["body"].replace("\n", "\\n")
            print(f"{r['id']}\t{r['created_at']}\t{r['sender']}\t{r['kind']}\t{ask}\t{body}")
        return

    db = connect()
    room = db.execute(
        "SELECT * FROM rooms WHERE name=?",
        (canonical_room_name(args.self, args.peer)[0],),
    ).fetchone()
    if room is None:
        print(f"no such room: {args.self} <-> {args.peer}", file=sys.stderr)
        sys.exit(1)
    q = "SELECT * FROM messages WHERE room_id=? "
    params = [room["id"]]
    if args.since:
        q += "AND id > ? "
        params.append(args.since)
    q += "ORDER BY id ASC "
    if args.limit:
        q += f"LIMIT {int(args.limit)}"
    for row in db.execute(q, params):
        ask = (row["ask"] or "").replace("\n", " ")
        body = row["body"].replace("\n", "\\n")
        print(f"{row['id']}\t{row['created_at']}\t{row['sender']}\t{row['kind']}\t{ask}\t{body}")
    db.close()


def cmd_show(args):
    """Pretty markdown render of recent messages (for human viewing)."""
    host = discover_host()
    if host:
        url = host
        text = http("GET", url, "/show",
                    params={"self": args.self, "peer": args.peer, "limit": args.limit})
        sys.stdout.write(text)
        return

    db = connect()
    name = canonical_room_name(args.self, args.peer)[0]
    room = db.execute("SELECT * FROM rooms WHERE name=?", (name,)).fetchone()
    if room is None:
        print(f"no such room: {args.self} <-> {args.peer}", file=sys.stderr)
        sys.exit(1)
    print(f"# Room: {room['participant_a']} ↔ {room['participant_b']}")
    print(f"Created: {time.strftime('%Y-%m-%d %H:%M', time.localtime(room['created_at']))}")
    print(f"当前发言权: {room['current_turn']}\n---\n")
    msgs = db.execute(
        "SELECT * FROM messages WHERE room_id=? ORDER BY id DESC LIMIT ?",
        (room["id"], args.limit),
    ).fetchall()
    for row in reversed(msgs):
        ts = time.strftime("%Y-%m-%d %H:%M PDT", time.localtime(row["created_at"]))
        print(f"### [{row['sender']} @ {ts}] {row['kind']}")
        print(row["body"])
        if row["ask"]:
            print(f"\n**Ask**: {row['ask']}")
        print()
    db.close()


def cmd_turn(args):
    host = discover_host()
    if host:
        url = host
        r = http("GET", url, "/turn", params={"self": args.self, "peer": args.peer})
        print(r["turn"])
        return
    db = connect()
    name = canonical_room_name(args.self, args.peer)[0]
    row = db.execute("SELECT current_turn FROM rooms WHERE name=?", (name,)).fetchone()
    if row is None:
        print(f"no such room: {args.self} <-> {args.peer}", file=sys.stderr)
        sys.exit(1)
    print(row["current_turn"])
    db.close()


def cmd_delete(args):
    """Delete a room (and all its messages) atomically.

    Hard delete — no soft-delete / archive. The caller (SKILL.md) is responsible
    for confirming with the user before invoking this.
    """
    host = discover_host()
    if host:
        url = host
        r = http("DELETE", url, "/room", params={"self": args.self, "peer": args.peer})
        print(f"deleted: room={r['room']} ({r['msg_count']} msgs purged)")
        return
    name = canonical_room_name(args.self, args.peer)[0]
    db = connect()
    db.execute("BEGIN IMMEDIATE")
    try:
        row = db.execute("SELECT id FROM rooms WHERE name=?", (name,)).fetchone()
        if row is None:
            db.execute("ROLLBACK")
            print(f"no such room: {name}", file=sys.stderr)
            sys.exit(1)
        room_id = row["id"]
        msg_cnt = db.execute("SELECT COUNT(*) c FROM messages WHERE room_id=?", (room_id,)).fetchone()["c"]
        db.execute("DELETE FROM messages WHERE room_id=?", (room_id,))
        db.execute("DELETE FROM rooms WHERE id=?", (room_id,))
        db.execute("COMMIT")
        print(f"deleted: room={name} ({msg_cnt} msgs purged)")
    except Exception:
        db.execute("ROLLBACK")
        raise
    finally:
        db.close()


def cmd_ring(args):
    """Monitor query: for self, list new messages in rooms where turn=self.

    Output: one line per message: <msg_id>\t<peer>\t<ask_or_empty>
    Monitor uses this to track the cursor and emit notifications.
    """
    host = discover_host()
    if host:
        url = host
        rows = http("GET", url, "/ring", params={"self": args.self, "since": args.since})
        for r in rows:
            ask = (r.get("ask") or "").replace("\n", " ").replace("\t", " ")
            print(f"{r['id']}\t{r['peer']}\t{ask}")
        return
    db = connect()
    rows = db.execute(
        """
        SELECT m.id, m.sender, m.ask, r.participant_a, r.participant_b
          FROM messages m
          JOIN rooms r ON m.room_id = r.id
         WHERE r.current_turn = ?
           AND m.id > ?
           AND m.sender != ?
         ORDER BY m.id ASC
        """,
        (args.self, args.since, args.self),
    ).fetchall()
    for row in rows:
        # The peer is whichever participant is not self.
        peer = row["participant_a"] if row["sender"] == row["participant_a"] else row["participant_b"]
        ask = (row["ask"] or "").replace("\n", " ").replace("\t", " ")
        print(f"{row['id']}\t{peer}\t{ask}")
    db.close()


def cmd_register(args):
    """Atomically add/update this session in directory.json.

    Schema: {name: {cwd, host, registered_at}}
    Conflict: if name exists AND its monitor is still alive, refuse (unless --force).
    """
    name = args.name
    cwd = args.cwd

    os.makedirs(os.path.dirname(DIRECTORY_PATH), exist_ok=True)
    # Load existing
    directory = {}
    if os.path.exists(DIRECTORY_PATH):
        try:
            with open(DIRECTORY_PATH) as f:
                directory = json.load(f)
        except Exception:
            directory = {}

    # Conflict check
    if name in directory and not args.force:
        if monitor_alive(name):
            print(f"error: '{name}' is already registered and its monitor is still running. "
                  f"Use --force to override.", file=sys.stderr)
            sys.exit(1)

    directory[name] = {
        "cwd": cwd,
        "host": socket.gethostname(),
        "registered_at": int(time.time()),
    }

    # Atomic write via tmp + os.replace
    tmp_path = DIRECTORY_PATH + ".tmp"
    with open(tmp_path, "w", encoding="utf-8") as f:
        json.dump(directory, f, indent=2, ensure_ascii=False)
    os.replace(tmp_path, DIRECTORY_PATH)
    print(f"registered: {name} (cwd={cwd}, host={socket.gethostname()})")


def cmd_unregister(args):
    """Atomically remove a session from directory.json. Silent if not present."""
    name = args.name
    if not os.path.exists(DIRECTORY_PATH):
        return
    try:
        with open(DIRECTORY_PATH) as f:
            directory = json.load(f)
    except Exception:
        return
    if name not in directory:
        return
    del directory[name]
    tmp_path = DIRECTORY_PATH + ".tmp"
    with open(tmp_path, "w", encoding="utf-8") as f:
        json.dump(directory, f, indent=2, ensure_ascii=False)
    os.replace(tmp_path, DIRECTORY_PATH)
    print(f"unregistered: {name}")


LAUNCHD_LABEL = "com.tommy.agent-meeting"


def cmd_daemon(args):
    """Manage the local meeting-daemon.

    Mac: drives the launchd LaunchAgent (com.tommy.agent-meeting). All ops are
    idempotent. SessionStart hook will reinstall/restart the daemon on next
    Claude session if is_host=true, so `stop` is effectively "pause until next
    Claude restart" unless you also set is_host=false in config.json.

    Linux/Windows: not implemented — the daemon there is session-bound and dies
    with the SessionStart hook's parent shell. We print an error instead of
    pretending to manage it.
    """
    import platform
    import subprocess as sp
    if platform.system() != "Darwin":
        print("daemon mgmt currently mac-only (Linux/Windows daemon is session-bound)", file=sys.stderr)
        sys.exit(1)

    uid = os.getuid()
    domain = f"gui/{uid}"
    target = f"{domain}/{LAUNCHD_LABEL}"
    plist = os.path.expanduser(f"~/Library/LaunchAgents/{LAUNCHD_LABEL}.plist")

    if args.action == "status":
        r = sp.run(["launchctl", "print", target], capture_output=True, text=True)
        if r.returncode != 0:
            print(f"daemon: not registered with launchd ({LAUNCHD_LABEL})")
            print(f"plist on disk: {'yes' if os.path.exists(plist) else 'no'}")
            return
        # Pull a few interesting fields out of the print output
        keys = ("state =", "pid =", "program =", "path =")
        for line in r.stdout.splitlines():
            line = line.strip()
            if any(k in line for k in keys):
                print(line)

    elif args.action == "stop":
        r = sp.run(["launchctl", "bootout", target], capture_output=True, text=True)
        if r.returncode == 0 or "Could not find" in (r.stderr or "") or "No such process" in (r.stderr or ""):
            # Poll until the service is really gone (daemon's SIGTERM handler unpublishes mDNS first).
            for _ in range(20):  # max ~4s
                time.sleep(0.2)
                p = sp.run(["launchctl", "print", target], capture_output=True)
                if p.returncode != 0:
                    break
            print(f"daemon stopped: {LAUNCHD_LABEL}")
            print("(note: next Claude SessionStart with is_host=true will reinstall + restart it)")
        else:
            print(f"stop failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)

    elif args.action == "restart":
        # `kickstart -k` is launchd's atomic kill+respawn for an already-loaded service.
        # If the service isn't loaded yet, fall back to bootstrap.
        loaded = sp.run(["launchctl", "print", target], capture_output=True).returncode == 0
        if loaded:
            r = sp.run(["launchctl", "kickstart", "-k", target], capture_output=True, text=True)
            if r.returncode == 0:
                print(f"daemon restarted: {LAUNCHD_LABEL}")
                return
            print(f"kickstart failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)
        # Not loaded — bootstrap fresh
        if not os.path.exists(plist):
            print(f"plist missing: {plist}", file=sys.stderr)
            print("Run a Claude SessionStart with is_host=true to install it first.", file=sys.stderr)
            sys.exit(1)
        r = sp.run(["launchctl", "bootstrap", domain, plist], capture_output=True, text=True)
        if r.returncode == 0:
            print(f"daemon started: {LAUNCHD_LABEL}")
        else:
            print(f"bootstrap failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)


def cmd_list(args):
    """List all session names with liveness status and message count.

    Columns: <status>\t<name>\t<msgs>
      status: online | empty | historical
        online     = registered AND monitor process alive (per <tmpdir>/meeting-<name>.monitor_pid)
        empty      = registered in directory.json but monitor process gone
        historical = never in directory but appears as sender in DB
      msgs   = total messages sent by this name across all rooms

    Liveness signal: the monitor writes its own pid to
    <tmpdir>/meeting-<name>.monitor_pid at startup, and removes it on exit.
    We check process liveness via pid_alive() (cross-platform).
    """
    host = discover_host()
    if host:
        url = host
        rows = http("GET", url, "/list")
        for r in rows:
            print(f"{r['status']}\t{r['name']}\t{r['msgs']}")
        return

    directory = {}
    if os.path.exists(DIRECTORY_PATH):
        with open(DIRECTORY_PATH) as f:
            directory = json.load(f)

    db = connect()
    # msg count per sender across all rooms
    msg_counts = {
        r["sender"]: r["cnt"]
        for r in db.execute("SELECT sender, COUNT(*) AS cnt FROM messages GROUP BY sender")
    }
    db.close()

    online_names = {n for n in directory if monitor_alive(n)}
    empty_names = set(directory.keys()) - online_names
    historical_names = set(msg_counts.keys()) - online_names - empty_names

    rows = []
    for name in sorted(online_names):
        rows.append(("online", name, msg_counts.get(name, 0)))
    for name in sorted(empty_names):
        rows.append(("empty", name, msg_counts.get(name, 0)))
    for name in sorted(historical_names):
        rows.append(("historical", name, msg_counts.get(name, 0)))

    for status, name, msgs in rows:
        print(f"{status}\t{name}\t{msgs}")


# ---------- main ----------

def main():
    p = argparse.ArgumentParser(prog="meeting")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("init").set_defaults(func=cmd_init)

    s = sub.add_parser("send", help="insert a message and flip turn")
    s.add_argument("self", help="sender name (your registered meeting name)")
    s.add_argument("peer", help="peer name")
    s.add_argument("body", nargs="?", default=None,
                   help="message body inline; or `-` to read stdin; ignored when --body-file given")
    s.add_argument("--body-file", default=None,
                   help="path to a file containing the body — use this for any body with backticks, $(...), or other shell-special chars")
    s.add_argument("--kind", default="回应",
                   help="message kind/header, typically 开启|回应|总结 but any string allowed")
    s.add_argument("--ask", default=None, help="optional one-line ask")
    s.set_defaults(func=cmd_send)

    s = sub.add_parser("read", help="dump messages as TSV rows")
    s.add_argument("self")
    s.add_argument("peer")
    s.add_argument("--limit", type=int, default=30)
    s.add_argument("--since", type=int, default=0, help="only msgs with id > since")
    s.set_defaults(func=cmd_read)

    s = sub.add_parser("show", help="pretty markdown render")
    s.add_argument("self")
    s.add_argument("peer")
    s.add_argument("--limit", type=int, default=30)
    s.set_defaults(func=cmd_show)

    s = sub.add_parser("turn", help="print current turn-holder")
    s.add_argument("self")
    s.add_argument("peer")
    s.set_defaults(func=cmd_turn)

    s = sub.add_parser("ring", help="monitor query: new msgs in rooms where turn=self")
    s.add_argument("self")
    s.add_argument("--since", type=int, default=0, help="only msgs with id > since")
    s.set_defaults(func=cmd_ring)

    sub.add_parser("list",
                   help="list all session names with status (online/empty/historical) + msg count").set_defaults(func=cmd_list)

    s = sub.add_parser("delete", help="delete a room and all its messages (hard delete, atomic)")
    s.add_argument("self")
    s.add_argument("peer")
    s.set_defaults(func=cmd_delete)

    s = sub.add_parser("daemon",
                       help="manage the local meeting daemon (Mac launchd; Linux/Windows daemon is session-bound and unmanaged)")
    s.add_argument("action", choices=["status", "stop", "restart"])
    s.set_defaults(func=cmd_daemon)

    s = sub.add_parser("register",
                       help="atomically add/update this session in directory.json")
    s.add_argument("name", help="session name to register")
    s.add_argument("--cwd", required=True, help="working directory of this session")
    s.add_argument("--force", action="store_true",
                   help="override even if monitor is still running")
    s.set_defaults(func=cmd_register)

    s = sub.add_parser("unregister",
                       help="atomically remove a session from directory.json (silent if not present)")
    s.add_argument("name", help="session name to unregister")
    s.set_defaults(func=cmd_unregister)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
