#!/usr/bin/env python3
"""
meeting — peer-to-peer agent messaging CLI backed by SQLite.

Messages are addressed sender->recipient; no room containers exist.
SQLite gives us atomic transactions, version-based optimistic concurrency,
unlimited history with O(log N) reads, and clean query semantics.

Database: ~/.agent-meeting/db/rooms.db (WAL mode for concurrent readers).

Identity: sessions are (project, name) composite. project is derived from
git rev-parse --show-toplevel basename, or cwd basename for non-git dirs.
Peer addressing: bare <name> resolves if globally unique across projects;
ambiguous names require <name>@<project> qualifier.

Usage:
  meeting init
  meeting send <self>[@project] <peer>[@project] <body> [--kind=X] [--ask=Y]
  meeting read <self>[@project] <peer>[@project] [--limit=30] [--since=ID]
  meeting show <self>[@project] <peer>[@project] [--limit=30]
  meeting turn <self>[@project] <peer>[@project]
  meeting list
  meeting online <name> --cwd <cwd>
  meeting offline <name>
"""

import argparse
import http.client as _http_client
import json
import os
import secrets
import signal
import socket
import sqlite3
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.parse
import urllib.request

_NO_PROXY_OPENER = urllib.request.build_opener(urllib.request.ProxyHandler({}))

MEETING_HOME = os.environ.get("MEETING_HOME") or os.path.expanduser("~/.agent-meeting")
DB_PATH = os.path.join(MEETING_HOME, "db", "rooms.db")

_TELEMETRY_URL = "https://www.woodor.ai/_functions/t"
_CONFIG_PATH = os.path.join(MEETING_HOME, "config.json")

if sys.platform == "darwin":
    _OS_LABEL = "mac"
elif sys.platform.startswith("win"):
    _OS_LABEL = "win"
else:
    _OS_LABEL = "linux"


def beacon(event: str):
    if os.environ.get("MEETING_NO_TELEMETRY"):
        return

    def _send():
        try:
            cfg = {}
            try:
                with open(_CONFIG_PATH) as _f:
                    cfg = json.load(_f)
            except Exception:
                pass
            if cfg.get("telemetry") is False:
                return
            machine_id = cfg.get("machine_id", "unknown")
            version = cfg.get("plugin_version", "unknown")
            params = urllib.parse.urlencode({
                "e": event,
                "id": machine_id,
                "v": version,
                "os": _OS_LABEL,
            })
            url = f"{_TELEMETRY_URL}?{params}"
            urllib.request.urlopen(url, timeout=2)
        except Exception:
            pass

    t = threading.Thread(target=_send, daemon=True)
    t.start()


HOST_CACHE = os.path.join(tempfile.gettempdir(), "meeting-host.cache")
HOST_CACHE_TTL = 60
MDNS_BROWSE_TIMEOUT = 1.5
SERVICE_TYPE = "_agent-meeting._tcp.local."

ONLINE_THRESHOLD = 12

_NO_CONTROL_MSG = (
    "未发现中央节点 (agent-meeting-control)。"
    "请先用 /meeting daemon 把本机设为中央节点，或确认目标 control 在线且同网段。"
)


# ---------- project derivation ----------

def _derive_project(cwd: str) -> str:
    """Derive project name from git repo root basename, or cwd basename."""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            cwd=cwd, capture_output=True, text=True, timeout=5,
        )
        if result.returncode == 0:
            top = result.stdout.strip()
            if top:
                return os.path.basename(top)
    except Exception:
        pass
    return os.path.basename(os.path.normpath(cwd))


# ---------- name resolution ----------

def _parse_name_arg(raw: str, cwd: str | None = None) -> tuple[str, str]:
    """Parse a bare name or name@project into (project, name).

    For a bare name with cwd, derive project from cwd.
    For a bare name without cwd, return ("", name) — caller resolves via daemon.
    """
    if "@" in raw:
        name, _, project = raw.partition("@")
        return (project, name)
    if cwd:
        return (_derive_project(cwd), raw)
    return ("", raw)


def _resolve_peer(host_url: str, raw: str, self_project: str) -> tuple[str, str]:
    """Resolve a peer name arg to (project, name).

    1. If raw has @project, use it directly.
    2. Otherwise query /resolve on the daemon.
       - 0 results: return (self_project, raw) as best-effort (may be historical-only).
       - 1 result: use it.
       - 2+ results: require @project qualifier and raise SystemExit.
    """
    if "@" in raw:
        name, _, project = raw.partition("@")
        return (project, name)

    try:
        candidates = http("GET", host_url, "/resolve", params={"name": raw})
    except Exception:
        return (self_project, raw)

    if not candidates:
        # Not found in any live session — fall back to same project as self
        return (self_project, raw)
    if len(candidates) == 1:
        return (candidates[0]["project"], raw)
    # Ambiguous
    options = ", ".join(f"{raw}@{c['project']}" for c in candidates)
    raise SystemExit(
        f"ambiguous name '{raw}' found in multiple projects. Use one of: {options}"
    )


# ---------- LAN discovery (mDNS + HTTP client) ----------

def discover_controls() -> list[dict]:
    if os.environ.get("MEETING_HOST"):
        url = os.environ["MEETING_HOST"].rstrip("/")
        parsed = urllib.parse.urlparse(url)
        ip = parsed.hostname or ""
        port = parsed.port or 8765
        return [{"url": url, "host": ip, "ip": ip, "port": port, "version": ""}]

    try:
        from zeroconf import IPVersion, ServiceBrowser, ServiceListener, Zeroconf
    except ImportError:
        return []

    found: list[dict] = []

    class _L(ServiceListener):
        def add_service(self, zc, type_, name):
            info = zc.get_service_info(type_, name, timeout=int(MDNS_BROWSE_TIMEOUT * 1000))
            if info and info.addresses:
                ip = socket.inet_ntoa(info.addresses[0])
                port = info.port
                url = f"http://{ip}:{port}"
                props = info.properties or {}
                host = (props.get(b"host") or b"").decode("utf-8", errors="replace")
                version = (props.get(b"version") or b"").decode("utf-8", errors="replace")
                found.append({"url": url, "host": host, "ip": ip, "port": port, "version": version})

        def update_service(self, *a): pass
        def remove_service(self, *a): pass

    for _attempt in range(3):
        try:
            zc = Zeroconf(ip_version=IPVersion.V4Only)
            ServiceBrowser(zc, SERVICE_TYPE, _L())
            time.sleep(MDNS_BROWSE_TIMEOUT)
            zc.close()
        except Exception:
            return found
        if found:
            break

    return found


def discover_host() -> str | None:
    if os.environ.get("MEETING_HOST"):
        return os.environ["MEETING_HOST"].rstrip("/")

    if os.path.exists(HOST_CACHE):
        try:
            with open(HOST_CACHE) as f:
                cache = json.load(f)
            if cache.get("expires", 0) > time.time() and cache.get("url"):
                return cache["url"]
        except Exception:
            pass

    controls = discover_controls()
    if not controls:
        return None

    url = controls[0]["url"]
    try:
        with open(HOST_CACHE, "w") as f:
            json.dump({"url": url, "expires": time.time() + HOST_CACHE_TTL}, f)
    except Exception:
        pass
    return url


def _invalidate_host_cache():
    try:
        os.remove(HOST_CACHE)
    except Exception:
        pass


def _resolve_host(explicit: str | None = None) -> str:
    if explicit:
        return explicit.rstrip("/")
    url = discover_host()
    if url:
        return url
    raise SystemExit(_NO_CONTROL_MSG)


def _get_auth_token() -> str | None:
    env_tok = os.environ.get("MEETING_TOKEN")
    if env_tok:
        return env_tok
    try:
        with open(_CONFIG_PATH) as _f:
            return json.load(_f).get("auth_token") or None
    except Exception:
        return None


def _http_once(method: str, host_url: str, path: str,
               params: dict | None, body: dict | None):
    url = host_url + path
    if params:
        url += "?" + urllib.parse.urlencode(params)
    headers = {}
    token = _get_auth_token()
    if token:
        headers["Authorization"] = f"Bearer {token}"
    data = None
    if body is not None:
        data = json.dumps(body, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json; charset=utf-8"
    req = urllib.request.Request(url, method=method, data=data, headers=headers)
    with _NO_PROXY_OPENER.open(req, timeout=10) as resp:
        ct = resp.headers.get("Content-Type", "")
        raw = resp.read()
        if "application/json" in ct:
            return json.loads(raw.decode("utf-8"))
        return raw.decode("utf-8")


def http(method: str, host_url: str, path: str,
         params: dict | None = None, body: dict | None = None):
    _BROKEN = (
        _http_client.RemoteDisconnected,
        _http_client.IncompleteRead,
        ConnectionError,
        socket.timeout,
        TimeoutError,
    )
    try:
        return _http_once(method, host_url, path, params, body)
    except urllib.error.HTTPError as e:
        err = e.read().decode("utf-8", errors="replace")
        raise SystemExit(f"daemon error: HTTP {e.code}: {err}")
    except urllib.error.URLError as e:
        _invalidate_host_cache()
        raise SystemExit(f"daemon unreachable at {host_url}: {e.reason}")
    except _BROKEN as e:
        _invalidate_host_cache()
        new_host = discover_host()
        if new_host is None:
            raise SystemExit(f"daemon connection broken and no daemon found on retry: {e}")
        try:
            return _http_once(method, new_host, path, params, body)
        except Exception as e2:
            raise SystemExit(f"daemon unreachable after retry: {e2}") from e2

SCHEMA = """
PRAGMA journal_mode = WAL;
PRAGMA foreign_keys = ON;

CREATE TABLE IF NOT EXISTS sessions (
  project       TEXT NOT NULL,
  name          TEXT NOT NULL,
  cwd           TEXT,
  host          TEXT,
  os            TEXT,
  registered_at TEXT,
  last_seen     REAL,
  role          TEXT NOT NULL DEFAULT 'worker',
  PRIMARY KEY (project, name)
);

CREATE TABLE IF NOT EXISTS messages (
  id               INTEGER PRIMARY KEY AUTOINCREMENT,
  sender_project   TEXT NOT NULL,
  sender           TEXT NOT NULL,
  recipient_project TEXT NOT NULL,
  recipient        TEXT NOT NULL,
  kind             TEXT NOT NULL,
  body             TEXT NOT NULL,
  ask              TEXT,
  created_at       INTEGER NOT NULL
);

CREATE INDEX IF NOT EXISTS idx_messages_recipient ON messages(recipient_project, recipient, id);
CREATE INDEX IF NOT EXISTS idx_messages_sender_recipient ON messages(sender_project, sender, recipient_project, recipient, id);

CREATE TABLE IF NOT EXISTS read_cursors (
  project     TEXT NOT NULL,
  member_name TEXT NOT NULL,
  cursor      INTEGER NOT NULL,
  updated_at  INTEGER NOT NULL,
  PRIMARY KEY (project, member_name)
);

CREATE TABLE IF NOT EXISTS groups (
  project    TEXT NOT NULL,
  name       TEXT NOT NULL,
  created_at INTEGER NOT NULL,
  creator    TEXT,
  PRIMARY KEY (project, name)
);

CREATE TABLE IF NOT EXISTS group_members (
  group_project  TEXT NOT NULL,
  group_name     TEXT NOT NULL,
  member_project TEXT NOT NULL,
  member_name    TEXT NOT NULL,
  added_at       INTEGER NOT NULL,
  PRIMARY KEY (group_project, group_name, member_project, member_name),
  FOREIGN KEY (group_project, group_name) REFERENCES groups(project, name) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_group_members_member ON group_members(member_project, member_name);
"""


# ---------- connection ----------

def connect():
    db = sqlite3.connect(DB_PATH, isolation_level=None, timeout=30)
    db.row_factory = sqlite3.Row
    db.executescript("PRAGMA journal_mode = WAL; PRAGMA foreign_keys = ON;")
    return db


def init_db():
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    db = connect()
    db.executescript(SCHEMA)
    db.close()


# ---------- commands ----------

def cmd_init(args):
    init_db()
    print(f"db ready: {DB_PATH}")


def cmd_send(args):
    if args.body_file:
        with open(args.body_file) as f:
            body = f.read().rstrip("\n")
    elif args.body == "-":
        body = sys.stdin.read().rstrip("\n")
    else:
        body = args.body
    if not body:
        raise SystemExit("error: body is empty")

    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()

    self_project, self_name = _parse_name_arg(args.self_arg, cwd)
    peer_project, peer_name = _resolve_peer(host, args.peer, self_project)

    payload = {
        "self_project": self_project, "self": self_name,
        "peer_project": peer_project, "peer": peer_name,
        "body": body, "kind": args.kind,
    }
    if args.ask:
        payload["ask"] = args.ask
    r = http("POST", host, "/send", body=payload)
    if r.get("turn") is None:
        print(f"sent: msg_id={r['msg_id']} broadcast->{peer_name}@{peer_project}")
    else:
        print(f"sent: msg_id={r['msg_id']} turn->{r['turn']}")
    beacon("send")


def cmd_read(args):
    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()
    self_project, self_name = _parse_name_arg(args.self_arg, cwd)
    peer_project, peer_name = _resolve_peer(host, args.peer, self_project)

    rows = http("GET", host, "/read",
                params={"self_project": self_project, "self": self_name,
                        "peer_project": peer_project, "peer": peer_name,
                        "limit": args.limit, "since": args.since})
    for r in rows:
        ask = (r.get("ask") or "").replace("\n", " ")
        body = r["body"].replace("\n", "\\n")
        print(f"{r['id']}\t{r['created_at']}\t{r['sender']}@{r['sender_project']}\t{r['kind']}\t{ask}\t{body}")


def cmd_show(args):
    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()
    self_project, self_name = _parse_name_arg(args.self_arg, cwd)
    peer_project, peer_name = _resolve_peer(host, args.peer, self_project)

    text = http("GET", host, "/show",
                params={"self_project": self_project, "self": self_name,
                        "peer_project": peer_project, "peer": peer_name,
                        "limit": args.limit})
    sys.stdout.write(text)


def cmd_turn(args):
    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()
    self_project, self_name = _parse_name_arg(args.self_arg, cwd)
    peer_project, peer_name = _resolve_peer(host, args.peer, self_project)

    r = http("GET", host, "/turn",
             params={"self_project": self_project, "self": self_name,
                     "peer_project": peer_project, "peer": peer_name})
    print(r["turn"])


def cmd_delete(args):
    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()
    self_project, self_name = _parse_name_arg(args.self_arg, cwd)
    peer_project, peer_name = _resolve_peer(host, args.peer, self_project)

    r = http("DELETE", host, "/conversation",
             params={"self_project": self_project, "self": self_name,
                     "peer_project": peer_project, "peer": peer_name})
    print(f"deleted: {self_name}@{self_project}<->{peer_name}@{peer_project} ({r['msg_count']} msgs purged)")


def cmd_online(args):
    name = args.name
    cwd = args.cwd
    project = _derive_project(cwd)
    host_name = socket.gethostname()

    explicit_host = getattr(args, "host", None)
    host = _resolve_host(explicit_host)

    if explicit_host:
        try:
            with open(HOST_CACHE, "w") as f:
                json.dump({"url": explicit_host.rstrip("/"), "expires": time.time() + HOST_CACHE_TTL}, f)
        except Exception:
            pass

    payload = {
        "project": project, "name": name, "cwd": cwd,
        "force": args.force,
        "role": "director" if args.director else None,
        "host": host_name, "os": _OS_LABEL,
    }
    r = http("POST", host, "/register", body=payload)
    if r.get("error"):
        print(r["error"], file=sys.stderr)
        sys.exit(1)
    print(f"online: {name}@{project} (cwd={cwd}, host={host_name})")
    beacon("register")


def cmd_rename(args):
    import re
    if not re.fullmatch(r"[A-Za-z0-9-]{2,20}", args.new) or "--" in args.new:
        print(f"invalid name '{args.new}': must be 2-20 chars, only [A-Za-z0-9-], no '--'",
              file=sys.stderr)
        sys.exit(1)
    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()
    project = _derive_project(cwd)
    r = http("POST", host, "/rename", body={"project": project, "old": args.old, "new": args.new})
    if r.get("error"):
        print(r["error"], file=sys.stderr)
        sys.exit(1)
    print(f"renamed: {r['old']}@{r['project']} -> {r['new']}@{r['project']} (messages: {r['messages_migrated']})")


def cmd_offline(args):
    name = args.name

    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()
    project = _derive_project(cwd)

    r = http("POST", host, "/unregister", body={"project": project, "name": name})
    if r.get("error"):
        print(r["error"], file=sys.stderr)
        sys.exit(1)
    print(f"offline: {name}@{project}")


LAUNCHD_LABEL = "com.tommy.agent-meeting"
SCHTASKS_TN = "agent-meeting-daemon"
DAEMON_PORT = int(os.environ.get("MEETING_PORT", "8765"))
STOP_SENTINEL = os.path.join(MEETING_HOME, "daemon.stopped")
_DAEMON_PID_FILE = os.path.join(tempfile.gettempdir(), "meeting-daemon.pid")
_SUPERVISOR_PID_FILE = os.path.join(tempfile.gettempdir(), "meeting-supervisor.pid")


def _win_pid_alive(pid: int) -> bool:
    if pid <= 0:
        return False
    import ctypes
    PROCESS_QUERY_LIMITED_INFORMATION = 0x1000
    handle = ctypes.windll.kernel32.OpenProcess(PROCESS_QUERY_LIMITED_INFORMATION, False, pid)
    if not handle:
        return False
    code = ctypes.c_ulong(0)
    ctypes.windll.kernel32.GetExitCodeProcess(handle, ctypes.byref(code))
    ctypes.windll.kernel32.CloseHandle(handle)
    return code.value == 259  # STILL_ACTIVE


def _read_pid(path: str) -> int:
    try:
        with open(path) as f:
            return int(f.read().strip())
    except Exception:
        return 0


def _probe_health() -> dict | None:
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{DAEMON_PORT}/health", timeout=5) as r:
            return json.loads(r.read().decode("utf-8"))
    except Exception:
        return None


def _cmd_daemon_windows(args):
    import subprocess as sp

    if args.action == "status":
        q = sp.run(["schtasks", "/Query", "/TN", SCHTASKS_TN, "/FO", "LIST"],
                   capture_output=True, text=True)
        if q.returncode != 0:
            print(f"logon task: not registered ({SCHTASKS_TN})")
        else:
            for line in q.stdout.splitlines():
                line = line.strip()
                if line.startswith(("TaskName:", "Status:", "Next Run Time:")):
                    print(line)
        sup = _read_pid(_SUPERVISOR_PID_FILE)
        print(f"supervisor: {'running pid='+str(sup) if _win_pid_alive(sup) else 'not running'}")
        dpid = _read_pid(_DAEMON_PID_FILE)
        print(f"daemon proc: {'running pid='+str(dpid) if _win_pid_alive(dpid) else 'not running'}")
        h = _probe_health()
        print(f"daemon /health: {'ok, version '+h.get('version','?') if h else 'unreachable'}")
        if os.path.exists(STOP_SENTINEL):
            print("stop sentinel: PRESENT (supervisor will not relaunch)")
        return

    if args.action == "stop":
        try:
            with open(STOP_SENTINEL, "w") as f:
                f.write(str(int(time.time())))
        except Exception as e:
            print(f"could not write stop sentinel: {e}", file=sys.stderr)
        sp.run(["schtasks", "/End", "/TN", SCHTASKS_TN], capture_output=True)
        for pid in (_read_pid(_DAEMON_PID_FILE), _read_pid(_SUPERVISOR_PID_FILE)):
            if pid > 0:
                sp.run(["taskkill", "/F", "/PID", str(pid)], capture_output=True)
        print(f"daemon stopped: {SCHTASKS_TN} (stop sentinel set)")
        print("(note: next Claude SessionStart with is_host=true clears the sentinel "
              "and reinstalls + restarts it)")
        return

    if args.action == "restart":
        try:
            os.remove(STOP_SENTINEL)
        except FileNotFoundError:
            pass
        if not _win_pid_alive(_read_pid(_SUPERVISOR_PID_FILE)):
            sp.run(["schtasks", "/Run", "/TN", SCHTASKS_TN], capture_output=True)
        dpid = _read_pid(_DAEMON_PID_FILE)
        if dpid > 0:
            sp.run(["taskkill", "/F", "/PID", str(dpid)], capture_output=True)
        print(f"daemon restarting: {SCHTASKS_TN} (supervisor will relaunch a fresh daemon)")
        return


def _cmd_daemon_start(sp, system: str):
    try:
        with open(_CONFIG_PATH) as f:
            cfg = json.load(f)
    except FileNotFoundError:
        cfg = {}
    cfg["is_host"] = True
    os.makedirs(os.path.dirname(_CONFIG_PATH), exist_ok=True)
    with open(_CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2)

    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT") or os.environ.get("PLUGIN_ROOT") or ""
    if not plugin_root:
        plugin_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))

    bootstrap = os.path.join(MEETING_HOME, "bin", "session-bootstrap.py")
    if os.path.exists(bootstrap):
        env = os.environ.copy()
        env["CLAUDE_PLUGIN_ROOT"] = plugin_root
        result = sp.run([sys.executable, bootstrap], env=env, capture_output=True, text=True)
        if result.returncode != 0:
            sys.stderr.write(result.stderr)
        print("daemon started: this machine is now the control node (agent-meeting-control)")
    else:
        daemon_script = os.path.join(plugin_root, "bin", "meeting-daemon")
        if not os.path.exists(daemon_script):
            raise SystemExit(f"daemon script not found: {daemon_script}")
        import tempfile as _tempfile
        log_file = os.path.join(_tempfile.gettempdir(), "meeting-daemon.log")
        if system == "Windows":
            flags = 0x00000008 | 0x00000200
            sp.Popen([sys.executable, daemon_script, "--port", "8765"],
                     stdout=open(log_file, "a"), stderr=sp.STDOUT,
                     creationflags=flags, close_fds=True)
        else:
            sp.Popen([sys.executable, daemon_script, "--port", "8765"],
                     stdout=open(log_file, "a"), stderr=sp.STDOUT,
                     start_new_session=True, close_fds=True)
        print("daemon started: this machine is now the control node (agent-meeting-control)")


def cmd_daemon(args):
    import platform
    import subprocess as sp
    system = platform.system()

    if not args.action:
        return _cmd_daemon_start(sp, system)

    if system == "Windows":
        return _cmd_daemon_windows(args)
    if system != "Darwin":
        print("daemon mgmt not supported on this platform (Linux daemon is session-bound)", file=sys.stderr)
        sys.exit(1)

    uid = os.getuid()
    domain = f"gui/{uid}"
    target = f"{domain}/{LAUNCHD_LABEL}"
    plist = os.path.expanduser(f"~/Library/LaunchAgents/{LAUNCHD_LABEL}.plist")

    if args.action == "status":
        r = sp.run(["launchctl", "print", target], capture_output=True, text=True)
        if r.returncode != 0:
            print(f"daemon: not registered with launchd ({LAUNCHD_LABEL})")
            print(f"plist on disk: {'yes' if os.path.exists(plist) else 'no'}")
            return
        keys = ("state =", "pid =", "program =", "path =")
        for line in r.stdout.splitlines():
            line = line.strip()
            if any(k in line for k in keys):
                print(line)
        try:
            cfg = json.load(open(_CONFIG_PATH))
        except Exception:
            cfg = {}
        if cfg.get("is_host"):
            healthy = _probe_health() is not None
            if not healthy:
                print(
                    f"\n本机应为 control，但 daemon 未在监听 :{DAEMON_PORT}。"
                    " 修复：launchctl 自愈未生效时跑 'meeting daemon restart'，"
                    " 或重开 Claude 会话触发自动拉起。"
                    " 详见 ~/.agent-meeting/logs/bootstrap.log"
                )

    elif args.action == "stop":
        r = sp.run(["launchctl", "bootout", target], capture_output=True, text=True)
        if r.returncode == 0 or "Could not find" in (r.stderr or "") or "No such process" in (r.stderr or ""):
            for _ in range(20):
                time.sleep(0.2)
                p = sp.run(["launchctl", "print", target], capture_output=True)
                if p.returncode != 0:
                    break
            print(f"daemon stopped: {LAUNCHD_LABEL}")
            print("(note: next Claude SessionStart with is_host=true will reinstall + restart it)")
        else:
            print(f"stop failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)

    elif args.action == "restart":
        loaded = sp.run(["launchctl", "print", target], capture_output=True).returncode == 0
        if loaded:
            r = sp.run(["launchctl", "kickstart", "-k", target], capture_output=True, text=True)
            if r.returncode == 0:
                print(f"daemon restarted: {LAUNCHD_LABEL}")
                return
            print(f"kickstart failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)
        if not os.path.exists(plist):
            print(f"plist missing: {plist}", file=sys.stderr)
            print("Run a Claude SessionStart with is_host=true to install it first.", file=sys.stderr)
            sys.exit(1)
        r = sp.run(["launchctl", "bootstrap", domain, plist], capture_output=True, text=True)
        if r.returncode == 0:
            print(f"daemon started: {LAUNCHD_LABEL}")
        else:
            print(f"bootstrap failed: {r.stderr.strip()}", file=sys.stderr)
            sys.exit(1)


def cmd_telemetry(args):
    try:
        with open(_CONFIG_PATH) as f:
            cfg = json.load(f)
    except FileNotFoundError:
        cfg = {}

    if args.action == "status":
        flag = cfg.get("telemetry")
        if flag is False:
            config_state = "disabled"
        else:
            config_state = "enabled"
        env_override = bool(os.environ.get("MEETING_NO_TELEMETRY"))
        print(f"telemetry: {config_state} (config.json)")
        if env_override:
            print("MEETING_NO_TELEMETRY is set -- environment variable overrides config and forces telemetry off")
    elif args.action == "off":
        cfg["telemetry"] = False
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print("telemetry disabled (config.json)")
    elif args.action == "on":
        cfg["telemetry"] = True
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print("telemetry enabled (config.json)")


def cmd_token(args):
    try:
        with open(_CONFIG_PATH) as f:
            cfg = json.load(f)
    except FileNotFoundError:
        cfg = {}

    value = getattr(args, "value", None)

    if value == "clear":
        cfg.pop("auth_token", None)
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print("auth_token cleared -- daemon is now open (no auth required)")
        return

    if value:
        cfg["auth_token"] = value
        with open(_CONFIG_PATH, "w") as f:
            json.dump(cfg, f, indent=2)
        print(f"auth_token set: {value}")
        return

    existing = cfg.get("auth_token")
    if existing:
        print(existing)
        print("(existing token -- distribute this to every client machine)")
        return

    new_token = secrets.token_urlsafe(32)
    cfg["auth_token"] = new_token
    with open(_CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2)
    print(new_token)
    print(
        "Token generated and written to config.json. "
        "Run `meeting token <value>` on every client machine to distribute it, "
        "or set the MEETING_TOKEN env var. Keep it secret."
    )


def _validate_group_name(name: str) -> str | None:
    import re
    if not re.fullmatch(r"[A-Za-z0-9-]{2,20}", name) or "--" in name:
        return f"invalid group name '{name}': must be 2-20 chars, only [A-Za-z0-9-], no '--'"
    return None


def cmd_group(args):
    host = _resolve_host(getattr(args, "host", None))
    cwd = os.getcwd()
    project = _derive_project(cwd)

    if args.group_cmd == "create":
        err = _validate_group_name(args.group_name)
        if err:
            print(err, file=sys.stderr)
            sys.exit(1)
        members = [m.strip() for m in args.members.split(",") if m.strip()]
        r = http("POST", host, "/group/create",
                 body={"project": project, "name": args.group_name,
                       "members": members, "creator": getattr(args, "creator", None)})
        if r.get("error"):
            print(r["error"], file=sys.stderr)
            sys.exit(1)
        print(f"group created: {args.group_name}@{project} members={r.get('members', members)}")

    elif args.group_cmd == "add":
        err = _validate_group_name(args.member)
        if err:
            print(err, file=sys.stderr)
            sys.exit(1)
        # member may carry @project
        if "@" in args.member:
            mname, _, mproj = args.member.partition("@")
        else:
            mname, mproj = args.member, project
        r = http("POST", host, "/group/add",
                 body={"group_project": project, "group": args.group_name,
                       "member_project": mproj, "member": mname})
        if r.get("error"):
            print(r["error"], file=sys.stderr)
            sys.exit(1)
        print(f"added {mname}@{mproj} to {args.group_name}@{project}")

    elif args.group_cmd == "remove":
        if "@" in args.member:
            mname, _, mproj = args.member.partition("@")
        else:
            mname, mproj = args.member, project
        r = http("POST", host, "/group/remove",
                 body={"group_project": project, "group": args.group_name,
                       "member_project": mproj, "member": mname})
        if r.get("error"):
            print(r["error"], file=sys.stderr)
            sys.exit(1)
        print(f"removed {mname}@{mproj} from {args.group_name}@{project}")

    elif args.group_cmd == "rename":
        r = http("POST", host, "/group/rename",
                 body={"project": project, "old": args.old_name, "new": args.new_name})
        if r.get("error"):
            print(r["error"], file=sys.stderr)
            sys.exit(1)
        print(f"group renamed: {args.old_name} -> {args.new_name} in project {project} ({r.get('messages_migrated', 0)} messages migrated)")

    elif args.group_cmd == "list":
        params = {}
        if getattr(args, "member", None):
            if "@" in args.member:
                mname, _, mproj = args.member.partition("@")
            else:
                mname, mproj = args.member, project
            params["member_project"] = mproj
            params["member"] = mname
        r = http("GET", host, "/group/list", params=params or None)
        for g in r:
            print(f"{g['name']}@{g['project']}\t{g.get('member_count', '')}")

    elif args.group_cmd == "members":
        r = http("GET", host, "/group/members",
                 params={"group_project": project, "group": args.group_name})
        if isinstance(r, dict) and r.get("error"):
            print(r["error"], file=sys.stderr)
            sys.exit(1)
        for m in r:
            print(m)

    elif args.group_cmd == "delete":
        r = http("DELETE", host, "/group",
                 params={"project": project, "name": args.group_name})
        if r.get("error"):
            print(r["error"], file=sys.stderr)
            sys.exit(1)
        print(f"group deleted: {args.group_name}@{project} ({r.get('purged', 0)} messages purged)")


def cmd_controls(args):
    controls = discover_controls()

    current_url = None
    if os.path.exists(HOST_CACHE):
        try:
            with open(HOST_CACHE) as f:
                cache = json.load(f)
            if cache.get("expires", 0) > time.time() and cache.get("url"):
                current_url = cache["url"]
        except Exception:
            pass

    if args.json:
        result = []
        for c in controls:
            result.append({
                "host": c.get("host") or "",
                "ip": c.get("ip") or "",
                "port": c.get("port") or 0,
                "url": c.get("url") or "",
                "version": c.get("version") or "",
                "is_current": c["url"] == current_url,
            })
        print(json.dumps(result, ensure_ascii=False))
        return

    if not controls:
        print("未发现 control 节点")
        return

    for i, c in enumerate(controls):
        is_current = c["url"] == current_url
        current_tag = "  当前" if is_current else ""
        print(f"control {i + 1}{current_tag}")
        print(f"  host:    {c['host'] or '(unknown)'}")
        print(f"  ip:port: {c['ip']}:{c['port']}")
        print(f"  url:     {c['url']}")
        print(f"  version: {c['version'] or '(unknown)'}")

def cmd_stop(args):
    run_dir = os.path.join(MEETING_HOME, "run")
    pid_file = os.path.join(run_dir, f"{args.name}.pid")

    if not os.path.exists(pid_file):
        print(f"no running monitor for '{args.name}'", file=sys.stderr)
        sys.exit(1)

    try:
        with open(pid_file) as f:
            pid = int(f.read().strip())
    except Exception as e:
        print(f"could not read pidfile: {e}", file=sys.stderr)
        sys.exit(1)

    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        try:
            os.remove(pid_file)
        except Exception:
            pass
        print(f"no running monitor for '{args.name}' (cleaned stale pidfile)", file=sys.stderr)
        sys.exit(1)

    os.kill(pid, signal.SIGTERM)

    deadline = time.monotonic() + 3.0
    while time.monotonic() < deadline:
        time.sleep(0.1)
        try:
            os.kill(pid, 0)
        except ProcessLookupError:
            print(f"stopped monitor: {args.name} (pid {pid})")
            return

    print(f"SIGTERM sent to monitor '{args.name}' (pid {pid}), but process has not exited within 3s")


def cmd_list(args):
    host = _resolve_host(getattr(args, "host", None))
    rows = http("GET", host, "/list")
    for r in rows:
        print(f"{r['status']}\t{r['name']}\t{r['project']}\t{r['msgs']}\t{r.get('role') or 'worker'}\t{r.get('cwd') or ''}\t{r.get('host') or ''}\t{r.get('os') or ''}")


# ---------- main ----------

def main():
    p = argparse.ArgumentParser(prog="meeting")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("init").set_defaults(func=cmd_init)

    s = sub.add_parser("send", help="insert a message and flip turn")
    s.add_argument("self_arg", metavar="self", help="sender name[@project]")
    s.add_argument("peer", help="peer name[@project]")
    s.add_argument("body", nargs="?", default=None,
                   help="message body inline; or `-` to read stdin; ignored when --body-file given")
    s.add_argument("--body-file", default=None)
    s.add_argument("--kind", default="回应")
    s.add_argument("--ask", default=None)
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_send)

    s = sub.add_parser("read", help="dump messages as TSV rows")
    s.add_argument("self_arg", metavar="self")
    s.add_argument("peer")
    s.add_argument("--limit", type=int, default=30)
    s.add_argument("--since", type=int, default=0)
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_read)

    s = sub.add_parser("show", help="pretty markdown render")
    s.add_argument("self_arg", metavar="self")
    s.add_argument("peer")
    s.add_argument("--limit", type=int, default=30)
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_show)

    s = sub.add_parser("turn", help="print current turn-holder")
    s.add_argument("self_arg", metavar="self")
    s.add_argument("peer")
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_turn)

    s = sub.add_parser("list", help="list all session names with status + msg count")
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_list)

    s = sub.add_parser("delete", help="clear all messages with a peer (hard delete, atomic)")
    s.add_argument("self_arg", metavar="self")
    s.add_argument("peer")
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_delete)

    s = sub.add_parser("daemon",
                       help="manage the local meeting daemon; bare `daemon` promotes this machine to control node")
    s.add_argument("action", nargs="?", choices=["status", "stop", "restart"], default=None)
    s.set_defaults(func=cmd_daemon)

    s = sub.add_parser("controls",
                       help="list all discovered control nodes")
    s.add_argument("--json", action="store_true", default=False)
    s.set_defaults(func=cmd_controls)

    s = sub.add_parser("telemetry")
    s.add_argument("action", choices=["on", "off", "status"])
    s.set_defaults(func=cmd_telemetry)

    s = sub.add_parser("token")
    s.add_argument("value", nargs="?", default=None)
    s.set_defaults(func=cmd_token)

    s = sub.add_parser("online",
                       help="bring this session online (register in the directory)")
    s.add_argument("name", help="session name to bring online")
    s.add_argument("--cwd", required=True)
    s.add_argument("--force", action="store_true")
    s.add_argument("--director", action="store_true")
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_online)

    s = sub.add_parser("offline",
                       help="take this session offline")
    s.add_argument("name")
    s.add_argument("--host", default=None)
    s.set_defaults(func=cmd_offline)

    sp = sub.add_parser("stop",
                       help="stop the local monitor process for a session")
    sp.add_argument("name")
    sp.set_defaults(func=cmd_stop)

    rp = sub.add_parser("rename",
                        help="rename a session and migrate all its messages (same project only)")
    rp.add_argument("old", help="current session name")
    rp.add_argument("new", help="new session name (2-20 chars, [A-Za-z0-9-], no '--')")
    rp.add_argument("--host", default=None)
    rp.set_defaults(func=cmd_rename)

    gp = sub.add_parser("group", help="manage groups")
    gp.add_argument("--host", default=None)
    gsub = gp.add_subparsers(dest="group_cmd", required=True)

    gc = gsub.add_parser("create", help="create a group")
    gc.add_argument("group_name")
    gc.add_argument("--members", required=True, help="comma-separated member names (bare or name@project)")
    gc.add_argument("--creator", default=None)

    ga = gsub.add_parser("add", help="add a member to a group")
    ga.add_argument("group_name")
    ga.add_argument("member", help="member name (bare or name@project)")

    gr = gsub.add_parser("remove", help="remove a member from a group")
    gr.add_argument("group_name")
    gr.add_argument("member", help="member name (bare or name@project)")

    gnr = gsub.add_parser("rename", help="rename a group (cascades group_members + messages)")
    gnr.add_argument("old_name")
    gnr.add_argument("new_name")

    gl = gsub.add_parser("list", help="list groups (optionally filter by member)")
    gl.add_argument("--member", default=None, help="filter by member (bare or name@project)")

    gm = gsub.add_parser("members", help="list members of a group")
    gm.add_argument("group_name")

    gd = gsub.add_parser("delete", help="delete a group and purge its messages")
    gd.add_argument("group_name")

    gp.set_defaults(func=cmd_group)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
