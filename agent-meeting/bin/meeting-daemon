#!/usr/bin/env python3
"""
meeting-daemon — HTTP+mDNS server for LAN-wide agent-meeting.

Single-host model: this process owns the SQLite DB. Other machines on the
LAN discover us via mDNS (_agent-meeting._tcp.local.) and hit our HTTP API
to do all operations (register / unregister / send / read / show /
turn / list / delete) — no direct DB access from clients.

Localhost clients also go through HTTP (uniform code path; localhost RTT
is <1ms so the cost is negligible).

Auth model: open by default (trusted-network assumption). Set `auth_token`
in config.json to enable Bearer-token enforcement on all routes except
/health. Token is re-read on every request — no daemon restart required
after `meeting token` writes it.

Usage:
  meeting-daemon [--port 8765] [--bind 0.0.0.0]

Run forever; stop with SIGINT/SIGTERM (mDNS unregister + clean shutdown).
"""

import argparse
import base64
import contextlib
import hashlib
import json
import os
import ipaddress
import re as _re
import signal
import socket
import sqlite3
import struct
import sys
import threading
import time
import traceback
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import parse_qs, urlparse

MEETING_HOME = os.environ.get("MEETING_HOME") or os.path.expanduser("~/.agent-meeting")
DB_PATH = os.path.join(MEETING_HOME, "db", "rooms.db")
_CONFIG_PATH = os.path.join(MEETING_HOME, "config.json")
SERVICE_TYPE = "_agent-meeting._tcp.local."

try:
    with open(_CONFIG_PATH) as _f:
        _plugin_version: str = json.load(_f).get("plugin_version") or "unknown"
except Exception:
    _plugin_version = "unknown"

# A session is considered online if last_seen is within this many seconds.
ONLINE_THRESHOLD = 12

# ---------- WebSocket global state ----------

class Subscriber:
    __slots__ = ("name", "sock", "wfile", "high_water_mark", "state", "send_lock", "last_pong")

    def __init__(self, name: str, sock, wfile, cursor: int):
        self.name = name
        self.sock = sock
        self.wfile = wfile
        self.high_water_mark = cursor  # only msgs with id > this are sent
        self.state = "draining"        # "draining" | "live"
        self.send_lock = threading.Lock()
        self.last_pong = time.time()


# name → list[Subscriber]  (list because same name can reconnect before old conn dies)
_subscribers: dict[str, list["Subscriber"]] = {}
_sub_lock = threading.Lock()


def _ws_remove(sub: "Subscriber"):
    """Remove a Subscriber from the global table. Safe to call multiple times."""
    with _sub_lock:
        lst = _subscribers.get(sub.name)
        if lst:
            try:
                lst.remove(sub)
            except ValueError:
                pass
            if not lst:
                del _subscribers[sub.name]
    # Flush in-memory high_water_mark to DB so reconnect resumes from here.
    if sub.high_water_mark > 0:
        try:
            with db() as conn:
                conn.execute(
                    "INSERT INTO read_cursors (member_name, cursor, updated_at) VALUES (?, ?, ?)"
                    " ON CONFLICT(member_name) DO UPDATE SET"
                    "  cursor=MAX(excluded.cursor, read_cursors.cursor),"
                    "  updated_at=excluded.updated_at",
                    (sub.name, sub.high_water_mark, int(time.time())),
                )
        except Exception:
            pass
    try:
        sub.sock.close()
    except Exception:
        pass


# ---------- RFC6455 minimal frame helpers ----------

def _ws_send_text(sub: "Subscriber", payload: str) -> bool:
    """Send a WebSocket text frame. Returns False on write failure → caller should remove sub."""
    data = payload.encode("utf-8")
    length = len(data)
    if length < 126:
        header = struct.pack("!BB", 0x81, length)
    elif length < 65536:
        header = struct.pack("!BBH", 0x81, 126, length)
    else:
        header = struct.pack("!BBQ", 0x81, 127, length)
    try:
        sub.wfile.write(header + data)
        sub.wfile.flush()
        return True
    except Exception:
        return False


def _ws_send_ping(sub: "Subscriber") -> bool:
    """Send a WebSocket ping frame (opcode 0x9, empty payload)."""
    try:
        sub.wfile.write(b"\x89\x00")
        sub.wfile.flush()
        return True
    except Exception:
        return False


def _ws_send_close(sub: "Subscriber"):
    """Send a WebSocket close frame (best-effort)."""
    try:
        sub.wfile.write(b"\x88\x00")
        sub.wfile.flush()
    except Exception:
        pass


def _ws_read_frame(rfile) -> tuple[int, bytes]:
    """Read one complete WebSocket frame from rfile.

    Returns (opcode, payload). Raises IOError / struct.error on EOF or
    malformed frame. Handles client masking (unmasks payload). Does NOT
    handle fragmentation — fragmented frames raise IOError.
    """
    header = rfile.read(2)
    if len(header) < 2:
        raise IOError("EOF reading frame header")
    b0, b1 = header[0], header[1]
    fin = (b0 & 0x80) != 0
    opcode = b0 & 0x0F
    masked = (b1 & 0x80) != 0
    length = b1 & 0x7F

    if not fin:
        raise IOError("fragmented frame not supported")

    if length == 126:
        ext = rfile.read(2)
        if len(ext) < 2:
            raise IOError("EOF reading 16-bit length")
        length = struct.unpack("!H", ext)[0]
    elif length == 127:
        ext = rfile.read(8)
        if len(ext) < 8:
            raise IOError("EOF reading 64-bit length")
        length = struct.unpack("!Q", ext)[0]

    mask_key = b""
    if masked:
        mask_key = rfile.read(4)
        if len(mask_key) < 4:
            raise IOError("EOF reading mask key")

    payload = b""
    if length:
        payload = rfile.read(length)
        if len(payload) < length:
            raise IOError("EOF reading payload")

    if masked:
        payload = bytes(b ^ mask_key[i % 4] for i, b in enumerate(payload))

    return opcode, payload


_AT_TOKEN_RE = _re.compile(r"@([A-Za-z0-9-]+)")


def _parse_mentions(body: str, member_set: set) -> set:
    """Return the intersection of @-tokens in body with member_set.

    Empty set means no valid mentions → broadcast semantics (no mention field).
    """
    tokens = set(_AT_TOKEN_RE.findall(body))
    return tokens & member_set


def _ws_fanout(msg_id: int, recipient: str, sender: str, ask: str | None, body: str = "", sender_project: str | None = None):
    """Push a message to all live/draining subscribers for recipient (or group members).

    Called after DB COMMIT. Uses per-subscriber send_lock + high_water_mark
    to ensure each subscriber sees each msg_id exactly once even if a
    backlog flush is in progress on the same connection's thread.

    For group messages: if the body contains @name tokens that resolve to group
    members, only those members' frames carry mention=true; others get mention=false.
    No @-mentions (or all invalid) → broadcast: no mention field added.
    """
    with db() as conn:
        is_grp = _is_group(conn, recipient)
        if is_grp:
            rows = conn.execute(
                "SELECT member_name FROM group_members WHERE group_name=?", (recipient,)
            ).fetchall()
            target_names = [r["member_name"] for r in rows]
        else:
            target_names = [recipient]

    group_field = recipient if is_grp else None

    # Compute mention set only for group messages.
    mention_targets: set = set()
    directed = False
    if is_grp and body:
        member_set = set(target_names)
        mention_targets = _parse_mentions(body, member_set)
        directed = bool(mention_targets)

    base_payload = {
        "type": "msg",
        "msg_id": msg_id,
        "sender": sender,
        "sender_project": sender_project or "",
        "ask": ask or "",
        "group": group_field,
        "phase": "live",
    }

    dead = []
    now = int(time.time())
    for target in target_names:
        if directed:
            payload = {**base_payload, "mention": target in mention_targets}
        else:
            payload = base_payload
        frame = json.dumps(payload, ensure_ascii=False)

        with _sub_lock:
            subs = list(_subscribers.get(target, []))
        for sub in subs:
            with sub.send_lock:
                if sub.state != "live":
                    continue  # draining — backlog thread owns this sub's stream
                if msg_id <= sub.high_water_mark:
                    continue  # already sent via backlog
                ok = _ws_send_text(sub, frame)
                if ok:
                    sub.high_water_mark = msg_id
                    # Persist cursor advance for this target member.
                    try:
                        with db() as conn2:
                            conn2.execute(
                                "INSERT INTO read_cursors (member_name, cursor, updated_at) VALUES (?, ?, ?)"
                                " ON CONFLICT(member_name) DO UPDATE SET"
                                "  cursor=MAX(excluded.cursor, read_cursors.cursor),"
                                "  updated_at=excluded.updated_at",
                                (target, msg_id, now),
                            )
                    except Exception:
                        pass
                else:
                    dead.append(sub)

    for sub in dead:
        _ws_remove(sub)


# ---------- heartbeat + pong-timeout sweep ----------

_WS_PING_INTERVAL = 4      # seconds between pings
_WS_PONG_TIMEOUT = 15      # seconds without pong → dead


def _ws_heartbeat_loop():
    """Background thread: ping all connected subscribers every 4s,
    and sweep for pong-timeout dead connections every 5s."""
    last_sweep = time.time()
    while True:
        time.sleep(_WS_PING_INTERVAL)
        now = time.time()

        with _sub_lock:
            all_subs = [s for lst in _subscribers.values() for s in lst]

        dead = []
        for sub in all_subs:
            if not _ws_send_ping(sub):
                dead.append(sub)

        # sweep for pong timeout every ~5s (one ping interval is close enough)
        if now - last_sweep >= 5:
            last_sweep = now
            for sub in all_subs:
                if now - sub.last_pong > _WS_PONG_TIMEOUT and sub not in dead:
                    dead.append(sub)

        for sub in dead:
            _ws_remove(sub)


# ---------- DB helpers ----------

@contextlib.contextmanager
def db():
    conn = sqlite3.connect(DB_PATH, isolation_level=None, timeout=30)
    conn.row_factory = sqlite3.Row
    conn.executescript("PRAGMA journal_mode = WAL; PRAGMA foreign_keys = ON; PRAGMA wal_autocheckpoint = 100;")
    try:
        yield conn
    finally:
        conn.close()


def _conversation_clause(a: str, b: str) -> tuple[str, list]:
    """Return WHERE clause + params for messages between a and b (both directions)."""
    clause = "((sender=? AND recipient=?) OR (sender=? AND recipient=?))"
    return clause, [a, b, b, a]


def _is_group(conn, name: str) -> bool:
    return conn.execute("SELECT 1 FROM groups WHERE name=?", (name,)).fetchone() is not None


# ---------- HTTP handlers ----------

class Handler(BaseHTTPRequestHandler):
    timeout = 30  # 30s per-connection timeout; prevents half-open connections blocking threads

    # Hide default request log — replace with one-liner.
    def log_message(self, fmt, *args):
        sys.stderr.write(f"{self.address_string()} {fmt % args}\n")

    # --- response helpers ---

    def _json(self, status: int, payload):
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _text(self, status: int, body: str):
        data = body.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def _err(self, status, msg):
        self._json(status, {"error": msg})

    def _check_auth(self, path: str) -> bool:
        """Return True if the request is allowed, False (and emit 401) if not.

        Re-reads config.json on every call so a token written by `meeting token`
        takes effect without a daemon restart. /health is always exempt.
        """
        if path == "/health":
            return True
        expected = None
        try:
            with open(_CONFIG_PATH) as _f:
                expected = json.load(_f).get("auth_token") or None
        except Exception:
            pass
        if not expected:
            return True
        auth_header = self.headers.get("Authorization", "")
        if auth_header == f"Bearer {expected}":
            return True
        self._json(401, {"error": "unauthorized"})
        return False

    def _query(self):
        return parse_qs(urlparse(self.path).query)

    def _read_json_body(self):
        n = int(self.headers.get("Content-Length", "0"))
        if not n:
            return {}
        return json.loads(self.rfile.read(n).decode("utf-8"))

    # --- routes ---

    def do_GET(self):
        path = urlparse(self.path).path
        if not self._check_auth(path):
            return

        # WebSocket upgrade — must be checked before the normal HTTP dispatch.
        if (path == "/subscribe" and
                self.headers.get("Upgrade", "").lower() == "websocket"):
            self._ws_upgrade()
            return  # _ws_upgrade blocks until connection closes

        if path == "/health":
            return self._json(200, {
                "ok": True,
                "host": socket.gethostname(),
                "version": _plugin_version,
            })
        q = self._query()
        try:
            if path == "/list":
                return self._json(200, self._list())
            if path == "/turn":
                return self._json(200, {"turn": self._turn(q["self"][0], q["peer"][0])})
            if path == "/show":
                return self._text(200, self._show(q["self"][0], q["peer"][0], int(q.get("limit", ["20"])[0])))
            if path == "/read":
                return self._json(200, self._read(q["self"][0], q["peer"][0],
                                                  int(q.get("limit", ["30"])[0]),
                                                  int(q.get("since", ["0"])[0])))
            if path == "/group/list":
                return self._json(200, self._group_list(q.get("member", [None])[0]))
            if path == "/group/members":
                return self._json(200, self._group_members(q["group"][0]))
            return self._err(404, f"no such GET route: {path}")
        except KeyError as e:
            return self._err(400, f"missing param: {e}")
        except Exception as e:
            sys.stderr.write(traceback.format_exc())
            return self._err(500, f"internal error: {e}")

    def _ws_upgrade(self):
        """Handle WebSocket upgrade on /subscribe.

        Performs the RFC6455 handshake, then blocks in the WS read loop
        until the connection closes. The Handler.timeout=30 is cleared after
        the handshake so the framework doesn't kill a long-lived connection.
        """
        # --- validate protocol version ---
        proto = self.headers.get("X-Meeting-Proto", "")
        if proto != "1":
            self._text(426, "Upgrade Required: X-Meeting-Proto must be 1")
            return

        # --- auth (mirrors _check_auth but without sending JSON 401) ---
        expected_token = None
        try:
            with open(_CONFIG_PATH) as _f:
                expected_token = json.load(_f).get("auth_token") or None
        except Exception:
            pass
        if expected_token:
            auth_header = self.headers.get("Authorization", "")
            if auth_header != f"Bearer {expected_token}":
                self.send_response(401)
                self.send_header("Content-Length", "0")
                self.end_headers()
                return

        name = self.headers.get("X-Meeting-Name", "").strip()
        if not name:
            self._err(400, "X-Meeting-Name required")
            return

        ws_key = self.headers.get("Sec-WebSocket-Key", "")
        if not ws_key:
            self._err(400, "Sec-WebSocket-Key required")
            return

        # --- RFC6455 accept key ---
        accept = base64.b64encode(
            hashlib.sha1((ws_key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11").encode()).digest()
        ).decode()

        self.send_response(101, "Switching Protocols")
        self.send_header("Upgrade", "websocket")
        self.send_header("Connection", "Upgrade")
        self.send_header("Sec-WebSocket-Accept", accept)
        self.end_headers()

        # Clear the 30s socket timeout so the framework doesn't kill long-lived WS connections.
        self.connection.settimeout(None)

        # Cursor is DB-authoritative. Ignore any client-supplied header.
        # First connect (no row): seed to MAX(id) so zero backlog is replayed.
        now = int(time.time())
        with db() as conn:
            row = conn.execute(
                "SELECT cursor FROM read_cursors WHERE member_name=?", (name,)
            ).fetchone()
            if row is None:
                max_row = conn.execute(
                    "SELECT COALESCE(MAX(id), 0) AS m FROM messages"
                ).fetchone()
                cursor = max_row["m"]
                conn.execute(
                    "INSERT INTO read_cursors (member_name, cursor, updated_at) VALUES (?, ?, ?)",
                    (name, cursor, now),
                )
            else:
                cursor = row["cursor"]

        sub = Subscriber(name, self.connection, self.wfile, cursor)

        # Register as draining, send backlog, switch to live.
        with _sub_lock:
            _subscribers.setdefault(name, []).append(sub)

        try:
            self._ws_send_backlog(sub, cursor)
            sys.stderr.write(f"[ws] {name} connected, cursor={cursor}\n")

            # Read loop — blocks until connection closes
            while True:
                try:
                    opcode, payload = _ws_read_frame(self.rfile)
                except Exception:
                    break  # EOF or malformed frame → close

                if opcode == 0xA:  # pong
                    sub.last_pong = time.time()
                    # Refresh liveness in DB (WS pong 时刷 last_seen)
                    try:
                        with db() as conn:
                            conn.execute(
                                "UPDATE sessions SET last_seen=? WHERE name=?",
                                (time.time(), name),
                            )
                    except Exception:
                        pass
                elif opcode == 0x9:  # ping from client — send pong
                    try:
                        self.wfile.write(b"\x8A" + bytes([len(payload)]) + payload)
                        self.wfile.flush()
                    except Exception:
                        break
                elif opcode == 0x8:  # close
                    _ws_send_close(sub)
                    break
                else:
                    # unexpected opcode — close per RFC6455
                    _ws_send_close(sub)
                    break
        finally:
            _ws_remove(sub)
            sys.stderr.write(f"[ws] {name} disconnected\n")

    def _ws_send_backlog(self, sub: "Subscriber", cursor: int):
        """Drain all messages with id > cursor to sub, then atomically flip state to live.

        Invariant: while state=="draining", only this thread sends to sub (fanout skips it).
        We loop until the DB has no more rows past our high_water_mark, checking under
        send_lock before flipping to "live" so there is no window where a concurrent
        fanout could slip a message past us.

        The backlog query is a union: recipient=self OR recipient IN groups that sub belongs to.
        This covers both 1:1 messages and group messages in one cursor-ordered stream.
        """
        while True:
            with sub.send_lock:
                hwm = sub.high_water_mark

            with db() as conn:
                rows = conn.execute(
                    "SELECT id, sender, recipient, ask, sender_project FROM messages"
                    " WHERE (recipient=? OR recipient IN"
                    "   (SELECT group_name FROM group_members WHERE member_name=?))"
                    " AND id>? ORDER BY id ASC LIMIT 500",
                    (sub.name, sub.name, hwm),
                ).fetchall()
                # Fetch group names in same conn for group field resolution
                group_names: set[str] = set()
                if rows:
                    recipients = set(r["recipient"] for r in rows)
                    for rcp in recipients:
                        if conn.execute("SELECT 1 FROM groups WHERE name=?", (rcp,)).fetchone():
                            group_names.add(rcp)

            if not rows:
                # No rows past hwm — check once more under send_lock before flipping live
                with sub.send_lock:
                    with db() as conn:
                        more = conn.execute(
                            "SELECT 1 FROM messages"
                            " WHERE (recipient=? OR recipient IN"
                            "   (SELECT group_name FROM group_members WHERE member_name=?))"
                            " AND id>? LIMIT 1",
                            (sub.name, sub.name, sub.high_water_mark),
                        ).fetchone()
                    if not more:
                        # Atomically flip to live inside send_lock — fanout's state check
                        # uses the same lock, so there is no gap between "no more rows"
                        # and "fanout starts delivering".
                        sub.state = "live"
                        hwm = sub.high_water_mark
                        caught_up_frame = json.dumps(
                            {"type": "caught_up", "cursor": hwm},
                            ensure_ascii=False,
                        )
                        _ws_send_text(sub, caught_up_frame)
                        # Persist the drained cursor to DB.
                        try:
                            with db() as conn:
                                conn.execute(
                                    "INSERT INTO read_cursors (member_name, cursor, updated_at) VALUES (?, ?, ?)"
                                    " ON CONFLICT(member_name) DO UPDATE SET"
                                    "  cursor=MAX(excluded.cursor, read_cursors.cursor),"
                                    "  updated_at=excluded.updated_at",
                                    (sub.name, hwm, int(time.time())),
                                )
                        except Exception:
                            pass
                        return
                    # New rows appeared between our DB read and the lock — loop again
                continue

            for row in rows:
                group_field = row["recipient"] if row["recipient"] in group_names else None
                frame = json.dumps({
                    "type": "msg",
                    "msg_id": row["id"],
                    "sender": row["sender"],
                    "sender_project": row["sender_project"] or "",
                    "ask": row["ask"] or "",
                    "group": group_field,
                    "phase": "backlog",
                }, ensure_ascii=False)
                with sub.send_lock:
                    if row["id"] <= sub.high_water_mark:
                        continue  # fanout cannot have sent this (state is draining), but be safe
                    ok = _ws_send_text(sub, frame)
                    if ok:
                        sub.high_water_mark = row["id"]
                    else:
                        _ws_remove(sub)
                        return

    def do_POST(self):
        path = urlparse(self.path).path
        if not self._check_auth(path):
            return
        try:
            body = self._read_json_body()
            if path == "/send":
                result = self._send(
                    body["self"], body["peer"], body["body"],
                    body.get("kind", "回应"),
                    body.get("ask"),
                )
                return self._json(200, result)
            if path == "/register":
                return self._json(200, self._register(
                    body["name"], body.get("cwd"), body.get("force", False), body.get("role"),
                    body.get("host"), body.get("os"), body.get("project")
                ))
            if path == "/unregister":
                return self._json(200, self._unregister(body["name"]))
            if path == "/rename":
                result = self._rename(body["old"], body["new"])
                status = 400 if result.get("error") else 200
                return self._json(status, result)
            if path == "/group/create":
                result = self._group_create(body["name"], body.get("members", []), body.get("creator"))
                status = 400 if result.get("error") else 200
                return self._json(status, result)
            if path == "/group/add":
                result = self._group_add(body["group"], body["member"])
                status = 400 if result.get("error") else 200
                return self._json(status, result)
            if path == "/group/remove":
                result = self._group_remove(body["group"], body["member"])
                status = 400 if result.get("error") else 200
                return self._json(status, result)
            return self._err(404, f"no such POST route: {path}")
        except KeyError as e:
            return self._err(400, f"missing param: {e}")
        except Exception as e:
            sys.stderr.write(traceback.format_exc())
            return self._err(500, f"internal error: {e}")

    def do_DELETE(self):
        path = urlparse(self.path).path
        if not self._check_auth(path):
            return
        q = self._query()
        try:
            if path == "/conversation":
                return self._json(200, self._delete(q["self"][0], q["peer"][0]))
            if path == "/group":
                return self._json(200, self._group_purge(q["name"][0]))
            return self._err(404, f"no such DELETE route: {path}")
        except KeyError as e:
            return self._err(400, f"missing param: {e}")
        except Exception as e:
            sys.stderr.write(traceback.format_exc())
            return self._err(500, f"internal error: {e}")

    # --- business logic (mirror meeting CLI cmd_*) ---

    def _list(self):
        now = time.time()
        with db() as conn:
            msg_counts = {
                r["sender"]: r["cnt"]
                for r in conn.execute("SELECT sender, COUNT(*) AS cnt FROM messages GROUP BY sender")
            }
            sessions = conn.execute("SELECT name, last_seen, cwd, role, host, os, project FROM sessions").fetchall()

        online_names = set()
        empty_names = set()
        cwd_by_name = {}
        role_by_name = {}
        host_by_name = {}
        os_by_name = {}
        project_by_name = {}
        for s in sessions:
            cwd_by_name[s["name"]] = s["cwd"]
            role_by_name[s["name"]] = s["role"]
            host_by_name[s["name"]] = s["host"]
            os_by_name[s["name"]] = s["os"]
            project_by_name[s["name"]] = s["project"]
            last_seen = s["last_seen"] or 0
            if now - last_seen <= ONLINE_THRESHOLD:
                online_names.add(s["name"])
            else:
                empty_names.add(s["name"])

        historical_names = set(msg_counts.keys()) - online_names - empty_names

        rows = []
        for n in sorted(online_names, key=lambda n: -msg_counts.get(n, 0)):
            rows.append({"status": "online", "name": n, "msgs": msg_counts.get(n, 0),
                         "role": role_by_name.get(n) or "worker", "cwd": cwd_by_name.get(n),
                         "host": host_by_name.get(n), "os": os_by_name.get(n),
                         "project": project_by_name.get(n)})
        for n in sorted(empty_names, key=lambda n: -msg_counts.get(n, 0)):
            rows.append({"status": "empty", "name": n, "msgs": msg_counts.get(n, 0),
                         "role": role_by_name.get(n) or "worker", "cwd": cwd_by_name.get(n),
                         "host": host_by_name.get(n), "os": os_by_name.get(n),
                         "project": project_by_name.get(n)})
        for n in sorted(historical_names, key=lambda n: -msg_counts.get(n, 0)):
            rows.append({"status": "historical", "name": n, "msgs": msg_counts.get(n, 0),
                         "role": "worker", "cwd": None, "host": None, "os": None, "project": None})
        return rows

    # _register and _unregister are unchanged

    def _register(self, name: str, cwd: str | None, force: bool, role: str | None = None,
                  host: str | None = None, os_label: str | None = None, project: str | None = None):
        now = time.time()
        with db() as conn:
            existing = conn.execute("SELECT last_seen FROM sessions WHERE name=?", (name,)).fetchone()
            if existing and not force:
                last_seen = existing["last_seen"] or 0
                if now - last_seen <= ONLINE_THRESHOLD:
                    return {
                        "error": (
                            f"'{name}' is already registered and its monitor is still running. "
                            "Use --force to override."
                        )
                    }
            conn.execute(
                "INSERT INTO sessions (name, cwd, host, os, registered_at, last_seen, role, project) VALUES (?, ?, ?, ?, ?, ?, COALESCE(?, 'worker'), ?) "
                "ON CONFLICT(name) DO UPDATE SET cwd=excluded.cwd, host=excluded.host, os=excluded.os, "
                "registered_at=excluded.registered_at, last_seen=excluded.last_seen, "
                "role=COALESCE(?, role), project=excluded.project",
                (name, cwd, host, os_label, str(int(now)), now, role, project, role),
            )
        return {"ok": True, "name": name}

    def _unregister(self, name: str):
        with db() as conn:
            conn.execute("DELETE FROM sessions WHERE name=?", (name,))
        return {"ok": True, "name": name}

    def _turn(self, self_name, peer):
        """Derive turn from the last message in the conversation.

        If no messages exist yet, the sender (self_name) holds the turn —
        mirroring the old ensure_room behavior where the room creator starts.
        """
        clause, params = _conversation_clause(self_name, peer)
        with db() as conn:
            row = conn.execute(
                f"SELECT recipient FROM messages WHERE {clause} ORDER BY id DESC LIMIT 1",
                params,
            ).fetchone()
        # No messages yet → self_name holds turn (creator convention)
        return row["recipient"] if row else self_name

    def _show(self, self_name, peer, limit):
        with db() as conn:
            is_grp = _is_group(conn, peer)
            if is_grp:
                msgs = conn.execute(
                    "SELECT * FROM messages WHERE recipient=? ORDER BY id DESC LIMIT ?",
                    (peer, limit),
                ).fetchall()
                lines = [f"# Group: {peer}\n---\n"]
                for row in reversed(msgs):
                    ts = time.strftime("%Y-%m-%d %H:%M PDT", time.localtime(row["created_at"]))
                    proj = row["sender_project"] or ""
                    sender_label = f"{row['sender']}@{proj}" if proj else row["sender"]
                    lines.append(f"### [{sender_label} @ {ts}] {row['kind']}")
                    lines.append(row["body"])
                    if row["ask"]:
                        lines.append(f"\n**Ask**: {row['ask']}")
                    lines.append("")
                return "\n".join(lines)

        clause, params = _conversation_clause(self_name, peer)
        turn = self._turn(self_name, peer)
        with db() as conn:
            msgs = conn.execute(
                f"SELECT * FROM messages WHERE {clause} ORDER BY id DESC LIMIT ?",
                params + [limit],
            ).fetchall()
        lines = [f"# Conversation: {self_name} ↔ {peer}",
                 f"当前发言权: {turn}\n---\n"]
        for row in reversed(msgs):
            ts = time.strftime("%Y-%m-%d %H:%M PDT", time.localtime(row["created_at"]))
            proj = row["sender_project"] or ""
            sender_label = f"{row['sender']}@{proj}" if proj else row["sender"]
            lines.append(f"### [{sender_label} @ {ts}] {row['kind']}")
            lines.append(row["body"])
            if row["ask"]:
                lines.append(f"\n**Ask**: {row['ask']}")
            lines.append("")
        return "\n".join(lines)

    def _read(self, self_name, peer, limit, since):
        with db() as conn:
            is_grp = _is_group(conn, peer)
        if is_grp:
            clause = "recipient=?"
            params: list = [peer]
        else:
            clause, params = _conversation_clause(self_name, peer)
        if since:
            clause += " AND id > ?"
            params.append(since)
        q = f"SELECT * FROM messages WHERE {clause} ORDER BY id ASC"
        if limit:
            q += f" LIMIT {int(limit)}"
        with db() as conn:
            rows = conn.execute(q, params).fetchall()
        return [dict(r) for r in rows]

    def _send(self, self_name, peer, body, kind, ask):
        if not body:
            raise KeyError("body empty")
        with db() as conn:
            conn.execute("BEGIN IMMEDIATE")
            try:
                sender_project_row = conn.execute(
                    "SELECT project FROM sessions WHERE name=?", (self_name,)
                ).fetchone()
                sender_project = sender_project_row["project"] if sender_project_row else None
                conn.execute(
                    "INSERT INTO messages (sender, recipient, kind, body, ask, created_at, sender_project) "
                    "VALUES (?, ?, ?, ?, ?, ?, ?)",
                    (self_name, peer, kind, body, ask, int(time.time()), sender_project),
                )
                msg_id = conn.execute("SELECT last_insert_rowid()").fetchone()[0]
                is_grp = _is_group(conn, peer)
                conn.execute("COMMIT")
            except Exception:
                conn.execute("ROLLBACK")
                raise

        # Fanout outside DB transaction — socket IO must not block DB writes.
        _ws_fanout(msg_id, peer, self_name, ask, body, sender_project)
        return {"msg_id": msg_id, "turn": None if is_grp else peer}

    def _group_create(self, name: str, members: list, creator: str | None):
        now = int(time.time())
        with db() as conn:
            # Reject if active session name
            if conn.execute("SELECT 1 FROM sessions WHERE name=?", (name,)).fetchone():
                return {"error": f"name '{name}' is already an active session name"}
            # Reject if existing group name
            if conn.execute("SELECT 1 FROM groups WHERE name=?", (name,)).fetchone():
                return {"error": f"group '{name}' already exists"}
            # Reject if historical messages use this name (as recipient or sender)
            if conn.execute(
                "SELECT 1 FROM messages WHERE recipient=? OR sender=? LIMIT 1", (name, name)
            ).fetchone():
                return {"error": f"name '{name}' has existing message history (cannot reuse as group name)"}

            conn.execute("BEGIN IMMEDIATE")
            try:
                conn.execute(
                    "INSERT INTO groups (name, created_at, creator) VALUES (?, ?, ?)",
                    (name, now, creator),
                )
                seen = set()
                for member in members:
                    if member in seen:
                        continue
                    seen.add(member)
                    conn.execute(
                        "INSERT OR IGNORE INTO group_members (group_name, member_name, added_at) VALUES (?, ?, ?)",
                        (name, member, now),
                    )
                # Seed read_cursors for each member that doesn't have a row yet
                max_row = conn.execute("SELECT COALESCE(MAX(id), 0) AS m FROM messages").fetchone()
                max_id = max_row["m"]
                for member in seen:
                    existing = conn.execute(
                        "SELECT 1 FROM read_cursors WHERE member_name=?", (member,)
                    ).fetchone()
                    if not existing:
                        conn.execute(
                            "INSERT INTO read_cursors (member_name, cursor, updated_at) VALUES (?, ?, ?)",
                            (member, max_id, now),
                        )
                conn.execute("COMMIT")
            except Exception:
                conn.execute("ROLLBACK")
                raise
        return {"ok": True, "name": name, "members": list(seen)}

    def _group_add(self, group: str, member: str):
        now = int(time.time())
        with db() as conn:
            if not conn.execute("SELECT 1 FROM groups WHERE name=?", (group,)).fetchone():
                return {"error": f"group '{group}' does not exist"}
            conn.execute(
                "INSERT OR IGNORE INTO group_members (group_name, member_name, added_at) VALUES (?, ?, ?)",
                (group, member, now),
            )
            # Seed read_cursors for this member if no row exists
            if not conn.execute(
                "SELECT 1 FROM read_cursors WHERE member_name=?", (member,)
            ).fetchone():
                max_row = conn.execute("SELECT COALESCE(MAX(id), 0) AS m FROM messages").fetchone()
                conn.execute(
                    "INSERT INTO read_cursors (member_name, cursor, updated_at) VALUES (?, ?, ?)",
                    (member, max_row["m"], now),
                )
        return {"ok": True, "group": group, "member": member}

    def _group_remove(self, group: str, member: str):
        with db() as conn:
            if not conn.execute("SELECT 1 FROM groups WHERE name=?", (group,)).fetchone():
                return {"error": f"group '{group}' does not exist"}
            conn.execute(
                "DELETE FROM group_members WHERE group_name=? AND member_name=?", (group, member)
            )
        return {"ok": True, "group": group, "member": member}

    def _group_list(self, member: str | None):
        with db() as conn:
            if member:
                rows = conn.execute(
                    "SELECT g.name, COUNT(gm2.member_name) AS member_count"
                    " FROM groups g"
                    " JOIN group_members gm ON g.name=gm.group_name AND gm.member_name=?"
                    " LEFT JOIN group_members gm2 ON g.name=gm2.group_name"
                    " GROUP BY g.name",
                    (member,),
                ).fetchall()
            else:
                rows = conn.execute(
                    "SELECT g.name, COUNT(gm.member_name) AS member_count"
                    " FROM groups g LEFT JOIN group_members gm ON g.name=gm.group_name"
                    " GROUP BY g.name",
                ).fetchall()
        return [{"name": r["name"], "member_count": r["member_count"]} for r in rows]

    def _group_members(self, group: str):
        with db() as conn:
            if not conn.execute("SELECT 1 FROM groups WHERE name=?", (group,)).fetchone():
                return {"error": f"group '{group}' does not exist"}
            rows = conn.execute(
                "SELECT member_name FROM group_members WHERE group_name=? ORDER BY member_name",
                (group,),
            ).fetchall()
        return [r["member_name"] for r in rows]

    def _group_purge(self, name: str):
        with db() as conn:
            conn.execute("BEGIN IMMEDIATE")
            try:
                cnt = conn.execute(
                    "SELECT COUNT(*) c FROM messages WHERE recipient=?", (name,)
                ).fetchone()["c"]
                conn.execute("DELETE FROM messages WHERE recipient=?", (name,))
                conn.execute("DELETE FROM groups WHERE name=?", (name,))
                conn.execute("COMMIT")
            except Exception:
                conn.execute("ROLLBACK")
                raise
        return {"ok": True, "purged": cnt}

    def _rename(self, old: str, new: str):
        with db() as conn:
            conn.execute("BEGIN IMMEDIATE")
            try:
                if not conn.execute("SELECT 1 FROM sessions WHERE name=?", (old,)).fetchone():
                    conn.execute("ROLLBACK")
                    return {"error": f"no such session: {old}"}
                if conn.execute("SELECT 1 FROM sessions WHERE name=?", (new,)).fetchone():
                    conn.execute("ROLLBACK")
                    return {"error": f"name already taken: {new}"}

                conn.execute("UPDATE sessions SET name=? WHERE name=?", (new, old))
                r1 = conn.execute("UPDATE messages SET sender=? WHERE sender=?", (new, old))
                r2 = conn.execute("UPDATE messages SET recipient=? WHERE recipient=?", (new, old))
                messages_migrated = r1.rowcount + r2.rowcount

                conn.execute("COMMIT")
                return {"ok": True, "old": old, "new": new, "messages_migrated": messages_migrated}
            except Exception:
                conn.execute("ROLLBACK")
                raise

    def _delete(self, self_name, peer):
        clause, params = _conversation_clause(self_name, peer)
        with db() as conn:
            conn.execute("BEGIN IMMEDIATE")
            try:
                cnt = conn.execute(
                    f"SELECT COUNT(*) c FROM messages WHERE {clause}", params
                ).fetchone()["c"]
                conn.execute(f"DELETE FROM messages WHERE {clause}", params)
                conn.execute("COMMIT")
                return {"deleted": True, "msg_count": cnt}
            except Exception:
                conn.execute("ROLLBACK")
                raise


# ---------- mDNS ----------

# Explicit LAN ranges. We do NOT use ipaddress.is_private to exclude tailscale:
# Python 3.13 classifies 100.64.0.0/10 as is_private=True, so that check would
# happily pick the tailscale CGNAT address. Match the RFC1918 ranges explicitly
# and exclude the CGNAT block by hand.
_RFC1918 = [
    ipaddress.ip_network("10.0.0.0/8"),
    ipaddress.ip_network("172.16.0.0/12"),
    ipaddress.ip_network("192.168.0.0/16"),
]
_CGNAT = ipaddress.ip_network("100.64.0.0/10")  # tailscale et al.


def _candidate_ips() -> set[str]:
    """Enumerate every local IPv4 address.

    Uses ifaddr (a zeroconf dependency, so always present here) to list ALL
    interface addresses directly. Route-based probes — connect("8.8.8.8") or
    getaddrinfo(hostname) — are useless on a tailscale host: the default route
    points at the tailscale interface, so they only ever surface the 100.x CGNAT
    address and never see the LAN NIC. We fall back to a probe only if ifaddr
    somehow can't be imported.
    """
    candidates: set[str] = set()
    try:
        import ifaddr

        for adapter in ifaddr.get_adapters():
            for ip in adapter.ips:
                if isinstance(ip.ip, str):  # str → IPv4; IPv6 comes as a tuple
                    candidates.add(ip.ip)
    except Exception:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        try:
            s.connect(("8.8.8.8", 80))
            candidates.add(s.getsockname()[0])
        except Exception:
            pass
        finally:
            s.close()
    return candidates


def pick_advertise_ip() -> str:
    """Pick the IP to broadcast over mDNS, preferring the LAN address.

    Meeting only ever talks over the LAN, so we enumerate every interface
    address and prefer RFC1918, explicitly avoiding the tailscale CGNAT block.
    """
    override = os.environ.get("MEETING_ADVERTISE_IP")
    if override:
        return override

    candidates = _candidate_ips()

    def score(ip: str) -> int:
        try:
            addr = ipaddress.ip_address(ip)
        except ValueError:
            return -1
        if addr in _CGNAT or addr.is_loopback or addr.is_link_local:
            return -1
        if any(addr in net for net in _RFC1918):
            return 2
        return 1  # public / other — last resort for LAN-less hosts

    best, best_score = "127.0.0.1", 0
    for ip in sorted(candidates):  # sorted → deterministic tie-break
        sc = score(ip)
        if sc > best_score:
            best, best_score = ip, sc
    return best


def publish_mdns(port: int):
    """Register this daemon as _agent-meeting._tcp.local. Returns ServiceInfo
    so caller can unregister on shutdown."""
    from zeroconf import IPVersion, ServiceInfo, Zeroconf

    zc = Zeroconf(ip_version=IPVersion.V4Only)
    hostname = socket.gethostname().replace(".local", "")
    instance = f"{hostname}-meeting"
    ip = pick_advertise_ip()

    info = ServiceInfo(
        SERVICE_TYPE,
        f"{instance}.{SERVICE_TYPE}",
        addresses=[socket.inet_aton(ip)],
        port=port,
        properties={
            b"version": _plugin_version.encode("utf-8"),
            b"host": hostname.encode("utf-8"),
        },
        server=f"{hostname}.local.",
    )
    zc.register_service(info)
    print(f"[mDNS] published {instance} → {ip}:{port}", flush=True)
    return zc, info


# ---------- main ----------

def main():
    p = argparse.ArgumentParser(prog="meeting-daemon")
    p.add_argument("--port", type=int, default=8765)
    p.add_argument("--bind", default="0.0.0.0")
    p.add_argument("--no-mdns", action="store_true", help="skip mDNS publish (for testing)")
    args = p.parse_args()

    if not os.path.exists(DB_PATH):
        print(f"DB not found at {DB_PATH}. Run `meeting init` first.", file=sys.stderr)
        sys.exit(1)

    # WAL hygiene: compact the WAL file at startup so it doesn't grow unbounded.
    with db() as conn:
        conn.execute("PRAGMA wal_checkpoint(TRUNCATE)")

    # Idempotent column additions and table creations.
    with db() as conn:
        try:
            conn.execute("ALTER TABLE sessions ADD COLUMN role TEXT NOT NULL DEFAULT 'worker'")
        except sqlite3.OperationalError:
            pass
        try:
            conn.execute("ALTER TABLE sessions ADD COLUMN os TEXT")
        except sqlite3.OperationalError:
            pass
        try:
            conn.execute("ALTER TABLE sessions ADD COLUMN project TEXT")
        except sqlite3.OperationalError:
            pass
        try:
            conn.execute("ALTER TABLE messages ADD COLUMN sender_project TEXT")
        except sqlite3.OperationalError:
            pass
        conn.execute(
            "CREATE TABLE IF NOT EXISTS read_cursors ("
            "  member_name TEXT PRIMARY KEY,"
            "  cursor      INTEGER NOT NULL,"
            "  updated_at  INTEGER NOT NULL)"
        )
        conn.execute(
            "CREATE TABLE IF NOT EXISTS groups ("
            "  name TEXT PRIMARY KEY,"
            "  created_at INTEGER NOT NULL,"
            "  creator TEXT)"
        )
        conn.execute(
            "CREATE TABLE IF NOT EXISTS group_members ("
            "  group_name TEXT NOT NULL,"
            "  member_name TEXT NOT NULL,"
            "  added_at INTEGER NOT NULL,"
            "  PRIMARY KEY (group_name, member_name),"
            "  FOREIGN KEY (group_name) REFERENCES groups(name) ON DELETE CASCADE)"
        )
        conn.execute(
            "CREATE INDEX IF NOT EXISTS idx_group_members_member ON group_members(member_name)"
        )

    ThreadingHTTPServer.allow_reuse_address = True
    server = ThreadingHTTPServer((args.bind, args.port), Handler)

    zc = info = None
    if not args.no_mdns:
        zc, info = publish_mdns(args.port)

    def shutdown(sig, _frame):
        # IMPORTANT: server.shutdown() blocks until serve_forever() returns.
        # Calling it directly from the signal handler (which runs in the main
        # thread alongside serve_forever) causes a deadlock. Offload to a
        # daemon thread so the main thread stays free to process the shutdown.
        print(f"\n[shutdown] received signal {sig}, unpublishing mDNS + stopping HTTP", flush=True)
        def _do():
            try:
                if zc and info:
                    zc.unregister_service(info)
                    zc.close()
            except Exception:
                pass
            server.shutdown()
            sys.exit(0)
        threading.Thread(target=_do, daemon=True).start()

    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    def _watchdog(port: int):
        # Self-connect every 10s; three consecutive failures (~30s) → hard exit.
        # Uses os._exit to bypass atexit hooks that may themselves be stuck.
        failures = 0
        time.sleep(15)  # give server time to start
        while True:
            try:
                s = socket.create_connection(("127.0.0.1", port), timeout=5)
                s.sendall(b"GET /health HTTP/1.0\r\nHost: localhost\r\n\r\n")
                s.recv(256)
                s.close()
                failures = 0
            except Exception:
                failures += 1
                print(f"[watchdog] health check failed ({failures}/3)", flush=True)
                if failures >= 3:
                    print("[watchdog] daemon unresponsive, forcing exit", flush=True)
                    os._exit(1)
            time.sleep(10)

    threading.Thread(target=_watchdog, args=(args.port,), daemon=True).start()
    threading.Thread(target=_ws_heartbeat_loop, daemon=True).start()

    print(f"[http] listening on {args.bind}:{args.port}", flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()
