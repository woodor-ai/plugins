{
  "description": "Auto-pickup handoff-pending.md on session start (startup/resume/clear/compact). Emits content as additionalContext and atomically archives to docs/handoff/archive/.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || py -3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || python \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\""
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || py -3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || python \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\""
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || py -3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || python \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\""
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || py -3 \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\" || python \"${CLAUDE_PLUGIN_ROOT}/bin/handoff-pickup.py\""
          }
        ]
      }
    ]
  }
}
